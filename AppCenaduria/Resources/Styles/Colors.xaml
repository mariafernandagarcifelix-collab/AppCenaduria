<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- ═══════════════════════════════════════════════════ -->
    <!--  Cenaduría El Parquesito – Premium Dark Theme      -->
    <!-- ═══════════════════════════════════════════════════ -->

    <!-- Brand Colors -->
    <Color x:Key="Primary">#fc4b08</Color>
    <Color x:Key="PrimaryDark">#E04200</Color>
    <Color x:Key="PrimaryLight">#FF7A3D</Color>
    <Color x:Key="PrimaryDarkText">#121212</Color>
    <Color x:Key="Secondary">#FFB088</Color>
    <Color x:Key="SecondaryDarkText">#fc4b08</Color>
    <Color x:Key="Tertiary">#FF6B2C</Color>

    <!-- Surface / Background Hierarchy -->
    <Color x:Key="SurfaceBase">#0D0D0D</Color>
    <Color x:Key="Surface1">#141414</Color>
    <Color x:Key="Surface2">#1A1A1A</Color>
    <Color x:Key="Surface3">#222222</Color>
    <Color x:Key="Surface4">#2A2A2A</Color>
    <Color x:Key="SurfaceElevated">#1E1E1E</Color>

    <!-- Text Hierarchy -->
    <Color x:Key="TextPrimary">#F5F5F5</Color>
    <Color x:Key="TextSecondary">#B8B8B8</Color>
    <Color x:Key="TextTertiary">#757575</Color>
    <Color x:Key="TextAccent">#fc4b08</Color>

    <!-- Borders & Dividers -->
    <Color x:Key="BorderSubtle">#2A2A2A</Color>
    <Color x:Key="BorderMedium">#3A3A3A</Color>
    <Color x:Key="BorderAccent">#fc4b08</Color>

    <!-- Status Colors -->
    <Color x:Key="StatusSuccess">#4CAF50</Color>
    <Color x:Key="StatusWarning">#FF9800</Color>
    <Color x:Key="StatusError">#F44336</Color>
    <Color x:Key="StatusInfo">#2196F3</Color>

    <!-- Legacy compatibility -->
    <Color x:Key="White">White</Color>
    <Color x:Key="Black">Black</Color>
    <Color x:Key="Magenta">#D600AA</Color>
    <Color x:Key="MidnightBlue">#190649</Color>
    <Color x:Key="OffBlack">#0D0D0D</Color>

    <Color x:Key="Gray100">#E1E1E1</Color>
    <Color x:Key="Gray200">#C8C8C8</Color>
    <Color x:Key="Gray300">#ACACAC</Color>
    <Color x:Key="Gray400">#919191</Color>
    <Color x:Key="Gray500">#6E6E6E</Color>
    <Color x:Key="Gray600">#404040</Color>
    <Color x:Key="Gray900">#212121</Color>
    <Color x:Key="Gray950">#141414</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource Primary}"/>
    <SolidColorBrush x:Key="SecondaryBrush" Color="{StaticResource Secondary}"/>
    <SolidColorBrush x:Key="TertiaryBrush" Color="{StaticResource Tertiary}"/>
    <SolidColorBrush x:Key="WhiteBrush" Color="{StaticResource White}"/>
    <SolidColorBrush x:Key="BlackBrush" Color="{StaticResource Black}"/>

    <SolidColorBrush x:Key="Gray100Brush" Color="{StaticResource Gray100}"/>
    <SolidColorBrush x:Key="Gray200Brush" Color="{StaticResource Gray200}"/>
    <SolidColorBrush x:Key="Gray300Brush" Color="{StaticResource Gray300}"/>
    <SolidColorBrush x:Key="Gray400Brush" Color="{StaticResource Gray400}"/>
    <SolidColorBrush x:Key="Gray500Brush" Color="{StaticResource Gray500}"/>
    <SolidColorBrush x:Key="Gray600Brush" Color="{StaticResource Gray600}"/>
    <SolidColorBrush x:Key="Gray900Brush" Color="{StaticResource Gray900}"/>
    <SolidColorBrush x:Key="Gray950Brush" Color="{StaticResource Gray950}"/>
</ResourceDictionary>
<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AppCenaduria.Views.Login"
             Title="Iniciar Sesión"
             BackgroundColor="#0D0D0D"
             NavigationPage.HasNavigationBar="False">

    <VerticalStackLayout Padding="30" Spacing="28" VerticalOptions="Center">

        <!-- Logo -->
        <Border BackgroundColor="#1A1A1A"
                StrokeThickness="0"
                WidthRequest="120"
                HeightRequest="120"
                HorizontalOptions="Center">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="60"/>
            </Border.StrokeShape>

            <Image Source="dotnet_bot.png"
                   HeightRequest="80"
                   HorizontalOptions="Center"
                   VerticalOptions="Center"/>
        </Border>

        <!-- Título -->
        <VerticalStackLayout Spacing="4">
            <Label Text="Cenaduría"
                   FontSize="36"
                   FontAttributes="Bold"
                   TextColor="#FF6B00"
                   HorizontalOptions="Center"/>

            <Label Text="El Parquesito"
                   FontSize="18"
                   TextColor="White"
                   HorizontalOptions="Center"/>
        </VerticalStackLayout>

        <!-- Botón estilo Google -->
        <Border BackgroundColor="White"
                Padding="12,0"
                HeightRequest="56"
                StrokeThickness="1"
                Stroke="#E0E0E0">

            <Border.StrokeShape>
                <RoundRectangle CornerRadius="14"/>
            </Border.StrokeShape>

            <Border.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnGoogleAuthClicked"/>
            </Border.GestureRecognizers>

            <Grid ColumnDefinitions="Auto, *" VerticalOptions="Center">

                <!-- Logo Google (agrega una imagen llamada google.png) -->
                <Image Source="google.png"
                       HeightRequest="22"
                       WidthRequest="22"
                       Margin="10,0"
                       VerticalOptions="Center"/>

                <Label Grid.Column="1"
                       Text="Continuar con Google"
                       TextColor="#444"
                       FontSize="15"
                       FontAttributes="Bold"
                       VerticalOptions="Center"
                       HorizontalOptions="Center"/>

            </Grid>

        </Border>

    </VerticalStackLayout>

</ContentPage>
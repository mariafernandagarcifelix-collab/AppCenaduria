<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AppCenaduria.Views.Login"
             Title="Iniciar Sesión"
             BackgroundColor="#0A0A0A"
             NavigationPage.HasNavigationBar="False">

    <Grid>

        <VerticalStackLayout Padding="34" Spacing="32" VerticalOptions="Center">

            <!-- ══ Logo Avatar ══ -->
            <Border BackgroundColor="#111111"
                    StrokeThickness="2"
                    Stroke="#fc4b08"
                    WidthRequest="130"
                    HeightRequest="130"
                    HorizontalOptions="Center">

                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="65"/>
                </Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="#fc4b08" Offset="0,0" Radius="30" Opacity="0.25"/>
                </Border.Shadow>

                <Grid>
                    <Grid.Clip>
                        <RoundRectangleGeometry CornerRadius="65" Rect="0,0,130,130"/>
                    </Grid.Clip>

                    <Image Source="logo_cenaduria.png"
                           Aspect="AspectFill"
                           HeightRequest="130"
                           WidthRequest="130"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"/>

                    <BoxView x:Name="shine"
                             Color="#88FFFFFF"
                             WidthRequest="40"
                             HeightRequest="200"
                             Rotation="25"
                             TranslationX="-120"
                             Opacity="0"
                             HorizontalOptions="Center"
                             VerticalOptions="Center"/>
                </Grid>
            </Border>

            <!-- ══ Brand Name ══ -->
            <VerticalStackLayout Spacing="6">
                <Label Text="Cenaduría"
                       FontSize="40"
                       FontAttributes="Bold"
                       TextColor="#fc4b08"
                       CharacterSpacing="1.5"
                       HorizontalOptions="Center"/>

                <Label Text="El Parquesito"
                       FontSize="20"
                       TextColor="#CCCCCC"
                       CharacterSpacing="3"
                       HorizontalOptions="Center"/>

                <BoxView HeightRequest="3" Color="#fc4b08" WidthRequest="50"
                         HorizontalOptions="Center" Margin="0,8,0,0">
                    <BoxView.Shadow>
                        <Shadow Brush="#fc4b08" Offset="0,0" Radius="10" Opacity="0.6"/>
                    </BoxView.Shadow>
                </BoxView>
            </VerticalStackLayout>

            <!-- ══ Google Sign-In Button ══ -->
            <Border x:Name="btnGoogle" BackgroundColor="#FAFAFA"
                    Padding="14,0"
                    HeightRequest="58"
                    StrokeThickness="1"
                    Stroke="#E8E8E8"
                    Margin="10,8">

                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="16"/>
                </Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="Black" Offset="0,4" Radius="16" Opacity="0.15"/>
                </Border.Shadow>

                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnGoogleAuthClicked"/>
                </Border.GestureRecognizers>

                <HorizontalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="14">

                    <Image Source="google_logo.png"
                           HeightRequest="40"
                           WidthRequest="40"
                           VerticalOptions="Center"/>

                    <Label x:Name="lblGoogleBtn" Text="Continuar con Google"
                           TextColor="#333333"
                           FontSize="16"
                           FontAttributes="Bold"
                           CharacterSpacing="0.3"
                           VerticalOptions="Center"/>

                    <ActivityIndicator x:Name="loaderGoogle" 
                                       IsVisible="False" 
                                       IsRunning="False" 
                                       Color="#fc4b08" 
                                       WidthRequest="22" 
                                       HeightRequest="22" 
                                       VerticalOptions="Center" />

                </HorizontalStackLayout>
            </Border>

            <!-- ══ Footer Decorative ══ -->
            <VerticalStackLayout Spacing="4" Margin="0,16,0,0">
                <Label Text="Tu comida favorita, a un toque"
                       TextColor="#444444" FontSize="12"
                       HorizontalOptions="Center" FontAttributes="Italic"/>
                <HorizontalStackLayout HorizontalOptions="Center" Spacing="6">
                    <BoxView HeightRequest="1" WidthRequest="30" Color="#222222" VerticalOptions="Center"/>
                    <Label Text="🍽️" FontSize="10"/>
                    <BoxView HeightRequest="1" WidthRequest="30" Color="#222222" VerticalOptions="Center"/>
                </HorizontalStackLayout>
            </VerticalStackLayout>

        </VerticalStackLayout>
    </Grid>
</ContentPage>
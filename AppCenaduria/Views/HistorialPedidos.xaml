<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AppCenaduria.Views.HistorialPedidos"
             Title="Mis Pedidos"
             BackgroundColor="#0A0A0A">

    <Grid RowDefinitions="Auto, *">

        <!-- ══ Header ══ -->
        <Border Grid.Row="0" StrokeThickness="0" BackgroundColor="#111111" Padding="24,28,24,20">
            <Border.StrokeShape><RoundRectangle CornerRadius="0,0,28,28"/></Border.StrokeShape>
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,8" Radius="20" Opacity="0.4"/>
            </Border.Shadow>
            <VerticalStackLayout Spacing="6">
                <HorizontalStackLayout HorizontalOptions="Center" Spacing="10">
                    <Border StrokeThickness="0" BackgroundColor="#1C1206" WidthRequest="38" HeightRequest="38">
                        <Border.StrokeShape><RoundRectangle CornerRadius="10"/></Border.StrokeShape>
                        <Label Text="📜" FontSize="16" HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>
                    <Label Text="Historial de Pedidos" FontSize="26" FontAttributes="Bold" TextColor="#F5F5F5" VerticalOptions="Center"/>
                </HorizontalStackLayout>
                <Label Text="Revisa el estado de tus compras anteriores" TextColor="#555555" FontSize="13" HorizontalOptions="Center"/>
                <BoxView HeightRequest="3" Color="#fc4b08" WidthRequest="40" HorizontalOptions="Center" Margin="0,6,0,0">
                    <BoxView.Shadow>
                        <Shadow Brush="#fc4b08" Offset="0,0" Radius="8" Opacity="0.5"/>
                    </BoxView.Shadow>
                </BoxView>
            </VerticalStackLayout>
        </Border>

        <!-- ══ Lista ══ -->
        <CollectionView x:Name="listaHistorial" Grid.Row="1" Margin="16,14,16,16">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border StrokeThickness="1" Stroke="#1E1E1E" BackgroundColor="#111111" 
                            Margin="0,0,0,12" Padding="18">
                        <Border.StrokeShape><RoundRectangle CornerRadius="18"/></Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="Black" Offset="0,4" Radius="12" Opacity="0.3"/>
                        </Border.Shadow>
                        <Grid RowDefinitions="Auto, Auto" ColumnDefinitions="*, Auto" RowSpacing="12">

                            <!-- Folio -->
                            <Label Grid.Row="0" Grid.Column="0" 
                                   Text="{Binding Folio, StringFormat='Orden #{0}'}" 
                                   FontSize="16" TextColor="#F0F0F0" FontAttributes="Bold"/>

                            <!-- Badge estado -->
                            <Border Grid.Row="0" Grid.Column="1" StrokeThickness="0" 
                                    BackgroundColor="#1C1206" Padding="10,5">
                                <Border.StrokeShape><RoundRectangle CornerRadius="8"/></Border.StrokeShape>
                                <Label Text="{Binding Estado}" TextColor="#fc4b08" FontSize="11" FontAttributes="Bold"/>
                            </Border>

                            <!-- Detalles -->
                            <VerticalStackLayout Grid.Row="1" Grid.ColumnSpan="2" Spacing="6">
                                <Label Text="{Binding Total, StringFormat='Total: ${0:F2}'}" 
                                       FontSize="18" FontAttributes="Bold" TextColor="#F5F5F5"/>
                                <BoxView HeightRequest="1" Color="#1E1E1E" Margin="0,2,0,4"/>
                                <HorizontalStackLayout Spacing="16">
                                    <Label Text="{Binding TipoEntrega, StringFormat='📦 {0}'}" FontSize="12" TextColor="#777777" FontAttributes="Bold"/>
                                    <Label Text="{Binding TipoPago, StringFormat='💳 {0}'}" FontSize="12" TextColor="#777777" FontAttributes="Bold"/>
                                </HorizontalStackLayout>
                            </VerticalStackLayout>

                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>

            <CollectionView.EmptyView>
                <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="10" Margin="0,60,0,0">
                    <Border StrokeThickness="1" Stroke="#1E1E1E" BackgroundColor="#111111" WidthRequest="70" HeightRequest="70" HorizontalOptions="Center">
                        <Border.StrokeShape><RoundRectangle CornerRadius="20"/></Border.StrokeShape>
                        <Label Text="📜" FontSize="28" HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>
                    <Label Text="Aún no tienes pedidos" TextColor="#555555" FontSize="16" FontAttributes="Bold" HorizontalOptions="Center"/>
                    <Label Text="Tus compras aparecerán aquí" TextColor="#333333" FontSize="12" HorizontalOptions="Center"/>
                </VerticalStackLayout>
            </CollectionView.EmptyView>
        </CollectionView>
    </Grid>
</ContentPage>
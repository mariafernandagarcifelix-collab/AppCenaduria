<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AppCenaduria.Views.HistorialPedidos"
             Title="Mis Pedidos"
             BackgroundColor="#0A0A0A">

    <Grid RowDefinitions="Auto, *">

        <!-- ══ Header ══ -->
        <Border Grid.Row="0" StrokeThickness="0" BackgroundColor="#111111" Padding="24,30,24,22">
            <Border.StrokeShape><RoundRectangle CornerRadius="0,0,30,30"/></Border.StrokeShape>
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,10" Radius="24" Opacity="0.45"/>
            </Border.Shadow>
            <VerticalStackLayout Spacing="6">
                <HorizontalStackLayout HorizontalOptions="Center" Spacing="10">
                    <Border StrokeThickness="0" BackgroundColor="#1C1206" WidthRequest="42" HeightRequest="42">
                        <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="#fc4b08" Offset="0,0" Radius="10" Opacity="0.2"/>
                        </Border.Shadow>
                        <Label Text="📜" FontSize="18" HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>
                    <Label Text="Historial de Pedidos" FontSize="26" FontAttributes="Bold" TextColor="#F5F5F5" VerticalOptions="Center" CharacterSpacing="0.3"/>
                </HorizontalStackLayout>
                <Label Text="Revisa el estado de tus compras anteriores" TextColor="#555555" FontSize="13" HorizontalOptions="Center"/>
                <BoxView HeightRequest="3" Color="#fc4b08" WidthRequest="44" HorizontalOptions="Center" Margin="0,6,0,0">
                    <BoxView.Shadow>
                        <Shadow Brush="#fc4b08" Offset="0,0" Radius="10" Opacity="0.5"/>
                    </BoxView.Shadow>
                </BoxView>
            </VerticalStackLayout>
        </Border>

        <!-- ══ List ══ -->
        <CollectionView x:Name="listaHistorial" Grid.Row="1" Margin="16,14,16,16">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border StrokeThickness="1" Stroke="#1E1E1E" BackgroundColor="#111111" 
                            Margin="0,0,0,12" Padding="20">
                        <Border.StrokeShape><RoundRectangle CornerRadius="20"/></Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="Black" Offset="0,4" Radius="14" Opacity="0.35"/>
                        </Border.Shadow>
                        <Grid RowDefinitions="Auto, Auto" ColumnDefinitions="*, Auto" RowSpacing="14">

                            <!-- Folio -->
                            <Label Grid.Row="0" Grid.Column="0" 
                                   Text="{Binding Folio, StringFormat='Orden #{0}'}" 
                                   FontSize="17" TextColor="#F0F0F0" FontAttributes="Bold" CharacterSpacing="0.3"/>

                            <!-- Status Badge -->
                            <Border Grid.Row="0" Grid.Column="1" StrokeThickness="0" 
                                    BackgroundColor="#1C1206" Padding="12,6">
                                <Border.StrokeShape><RoundRectangle CornerRadius="10"/></Border.StrokeShape>
                                <Label Text="{Binding Estado}" TextColor="#fc4b08" FontSize="11" FontAttributes="Bold"/>
                            </Border>

                            <!-- Details -->
                            <VerticalStackLayout Grid.Row="1" Grid.ColumnSpan="2" Spacing="8">
                                <Label Text="{Binding Total, StringFormat='Total: ${0:F2}'}" 
                                       FontSize="20" FontAttributes="Bold" TextColor="#F5F5F5"/>
                                <BoxView HeightRequest="1" Color="#1E1E1E" Margin="0,2,0,4"/>
                                <HorizontalStackLayout Spacing="20">
                                    <HorizontalStackLayout Spacing="5">
                                        <Label Text="📦" FontSize="12"/>
                                        <Label Text="{Binding TipoEntrega}" FontSize="12" TextColor="#777777" FontAttributes="Bold"/>
                                    </HorizontalStackLayout>
                                    <HorizontalStackLayout Spacing="5">
                                        <Label Text="💳" FontSize="12"/>
                                        <Label Text="{Binding TipoPago}" FontSize="12" TextColor="#777777" FontAttributes="Bold"/>
                                    </HorizontalStackLayout>
                                </HorizontalStackLayout>
                            </VerticalStackLayout>

                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>

            <CollectionView.EmptyView>
                <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="12" Margin="0,60,0,0">
                    <Border StrokeThickness="1" Stroke="#1E1E1E" BackgroundColor="#111111" WidthRequest="80" HeightRequest="80" HorizontalOptions="Center">
                        <Border.StrokeShape><RoundRectangle CornerRadius="24"/></Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="Black" Offset="0,4" Radius="12" Opacity="0.3"/>
                        </Border.Shadow>
                        <Label Text="📜" FontSize="32" HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>
                    <Label Text="Aún no tienes pedidos" TextColor="#555555" FontSize="17" FontAttributes="Bold" HorizontalOptions="Center"/>
                    <Label Text="Tus compras aparecerán aquí" TextColor="#333333" FontSize="13" HorizontalOptions="Center"/>
                </VerticalStackLayout>
            </CollectionView.EmptyView>
        </CollectionView>
    </Grid>
</ContentPage>
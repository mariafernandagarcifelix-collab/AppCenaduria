<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:syncfusion="clr-namespace:Syncfusion.Maui.DataGrid;assembly=Syncfusion.Maui.DataGrid"
             x:Class="AppCenaduria.Views.HistorialPedidos"
             Title="Mis Pedidos"
             BackgroundColor="#0A0A0A">

    <Grid RowDefinitions="Auto, *">

        <Border Grid.Row="0" StrokeThickness="0" BackgroundColor="#111111" Padding="24,30,24,22">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="0,0,30,30"/>
            </Border.StrokeShape>
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,10" Radius="24" Opacity="0.45"/>
            </Border.Shadow>
            <VerticalStackLayout Spacing="6">
                <HorizontalStackLayout HorizontalOptions="Center" Spacing="10">
                    <Border StrokeThickness="0" BackgroundColor="#1C1206" WidthRequest="42" HeightRequest="42">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12"/>
                        </Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="#fc4b08" Offset="0,0" Radius="10" Opacity="0.2"/>
                        </Border.Shadow>
                        <Label Text="📜" FontSize="18" HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>
                    <Label Text="Historial de Pedidos" FontSize="26" FontAttributes="Bold" TextColor="#F5F5F5" VerticalOptions="Center" CharacterSpacing="0.3"/>
                </HorizontalStackLayout>
                <Label Text="Revisa el estado de tus compras anteriores" TextColor="#555555" FontSize="13" HorizontalOptions="Center"/>
                <BoxView HeightRequest="3" Color="#fc4b08" WidthRequest="44" HorizontalOptions="Center" Margin="0,6,0,0">
                    <BoxView.Shadow>
                        <Shadow Brush="#fc4b08" Offset="0,0" Radius="10" Opacity="0.5"/>
                    </BoxView.Shadow>
                </BoxView>
            </VerticalStackLayout>
        </Border>

        <Grid Grid.Row="1" Margin="16,14,16,16">

            <syncfusion:SfDataGrid x:Name="listaHistorial" 
                                   AutoGenerateColumnsMode="None"
                                   ColumnWidthMode="Fill"
                                   HeaderRowHeight="0"
                                   RowHeight="170" 
                                   BackgroundColor="Transparent"
                                   GridLinesVisibility="None"
                                   SelectionMode="None">
                <syncfusion:SfDataGrid.Columns>
                    <syncfusion:DataGridTemplateColumn MappingName="Folio">
                        <syncfusion:DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border StrokeThickness="1" Stroke="#1E1E1E" BackgroundColor="#111111" Margin="0,0,0,12" Padding="20">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="20"/>
                                    </Border.StrokeShape>
                                    <Border.Shadow>
                                        <Shadow Brush="Black" Offset="0,4" Radius="14" Opacity="0.35"/>
                                    </Border.Shadow>
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnPedidoTapped" CommandParameter="{Binding .}"/>
                                    </Border.GestureRecognizers>

                                    <Grid RowDefinitions="Auto, Auto" ColumnDefinitions="*, Auto" RowSpacing="14">
                                        <Label Grid.Row="0" Grid.Column="0" Text="{Binding Folio, StringFormat='Orden #{0}'}" FontSize="17" TextColor="#F0F0F0" FontAttributes="Bold" CharacterSpacing="0.3"/>

                                        <Border Grid.Row="0" Grid.Column="1" StrokeThickness="0" BackgroundColor="#1C1206" Padding="12,6">
                                            <Border.StrokeShape>
                                                <RoundRectangle CornerRadius="10"/>
                                            </Border.StrokeShape>
                                            <Label Text="{Binding Estado}" TextColor="#fc4b08" FontSize="11" FontAttributes="Bold"/>
                                        </Border>

                                        <VerticalStackLayout Grid.Row="1" Grid.ColumnSpan="2" Spacing="8">
                                            <Label Text="{Binding Total, StringFormat='Total: ${0:F2}'}" FontSize="20" FontAttributes="Bold" TextColor="#F5F5F5"/>
                                            <BoxView HeightRequest="1" Color="#1E1E1E" Margin="0,2,0,4"/>
                                            <HorizontalStackLayout Spacing="20">
                                                <HorizontalStackLayout Spacing="5">
                                                    <Label Text="📦" FontSize="12"/>
                                                    <Label Text="{Binding TipoEntrega}" FontSize="12" TextColor="#777777" FontAttributes="Bold"/>
                                                </HorizontalStackLayout>
                                                <HorizontalStackLayout Spacing="5">
                                                    <Label Text="💳" FontSize="12"/>
                                                    <Label Text="{Binding TipoPago}" FontSize="12" TextColor="#777777" FontAttributes="Bold"/>
                                                </HorizontalStackLayout>
                                            </HorizontalStackLayout>
                                        </VerticalStackLayout>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </syncfusion:DataGridTemplateColumn.CellTemplate>
                    </syncfusion:DataGridTemplateColumn>
                </syncfusion:SfDataGrid.Columns>
            </syncfusion:SfDataGrid>

            <VerticalStackLayout x:Name="vistaVacia" IsVisible="False" HorizontalOptions="Center" VerticalOptions="Center" Spacing="12" Margin="0,60,0,0">
                <Border StrokeThickness="1" Stroke="#1E1E1E" BackgroundColor="#111111" WidthRequest="80" HeightRequest="80" HorizontalOptions="Center">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="24"/>
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="0,4" Radius="12" Opacity="0.3"/>
                    </Border.Shadow>
                    <Label Text="📜" FontSize="32" HorizontalOptions="Center" VerticalOptions="Center"/>
                </Border>
                <Label Text="Aún no tienes pedidos" TextColor="#555555" FontSize="17" FontAttributes="Bold" HorizontalOptions="Center"/>
                <Label Text="Tus compras aparecerán aquí" TextColor="#333333" FontSize="13" HorizontalOptions="Center"/>
            </VerticalStackLayout>
        </Grid>

        <Grid x:Name="modalTicket" Grid.RowSpan="4" IsVisible="False" BackgroundColor="#CC000000" Margin="-16,-10,-16,-16">
            <Border StrokeThickness="1" Stroke="#1E1E1E" BackgroundColor="#111111" WidthRequest="350" HorizontalOptions="Center" VerticalOptions="Center" Padding="28,26">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="26"/>
                </Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="Black" Offset="0,12" Radius="36" Opacity="0.6"/>
                </Border.Shadow>
                <VerticalStackLayout Spacing="8">
                    <Label Text="🍽️ CENADURÍA" FontAttributes="Bold" FontSize="20" TextColor="#fc4b08" HorizontalOptions="Center" CharacterSpacing="1.5"/>
                    <Label x:Name="lblTicketFolio" Text="Folio:" TextColor="#F0F0F0" FontAttributes="Bold" HorizontalOptions="Center" FontSize="14"/>
                    <BoxView HeightRequest="1" Color="#1E1E1E" Margin="0,10"/>

                    <Grid ColumnDefinitions="Auto, *" RowDefinitions="Auto, Auto, Auto" RowSpacing="6" ColumnSpacing="12">
                        <Label Grid.Row="0" Grid.Column="0" Text="Cliente:" TextColor="#777777" FontSize="13"/>
                        <Label Grid.Row="0" Grid.Column="1" x:Name="lblTicketCliente" TextColor="#DDDDDD" FontSize="13" FontAttributes="Bold" HorizontalOptions="End" LineBreakMode="WordWrap" HorizontalTextAlignment="End"/>

                        <Label Grid.Row="1" Grid.Column="0" Text="Fecha:" TextColor="#777777" FontSize="13"/>
                        <Label Grid.Row="1" Grid.Column="1" x:Name="lblTicketFecha" TextColor="#DDDDDD" FontSize="13" FontAttributes="Bold" HorizontalOptions="End"/>

                        <Label Grid.Row="2" Grid.Column="0" Text="Tipo:" TextColor="#777777" FontSize="13"/>
                        <Label Grid.Row="2" Grid.Column="1" x:Name="lblTicketTipo" TextColor="#DDDDDD" FontSize="13" FontAttributes="Bold" HorizontalOptions="End"/>
                    </Grid>

                    <BoxView HeightRequest="1" Color="#1E1E1E" Margin="0,10"/>

                    <CollectionView x:Name="listaDetallesTicket" MaximumHeightRequest="180">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="Auto, *, Auto" Padding="0,6">
                                    <Label Grid.Column="0" Text="{Binding Cantidad, StringFormat='{0}x '}" TextColor="#888888" FontSize="13" FontAttributes="Bold"/>
                                    <Label Grid.Column="1" Text="{Binding NombrePlatillo}" TextColor="#DDDDDD" FontSize="13" LineBreakMode="TailTruncation" Margin="6,0"/>
                                    <Label Grid.Column="2" Text="{Binding Subtotal, StringFormat='${0:F2}'}" TextColor="#F0F0F0" FontSize="13" FontAttributes="Bold"/>
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <BoxView HeightRequest="2" Color="#fc4b08" Margin="0,10">
                        <BoxView.Shadow>
                            <Shadow Brush="#fc4b08" Offset="0,0" Radius="6" Opacity="0.4"/>
                        </BoxView.Shadow>
                    </BoxView>
                    <Grid ColumnDefinitions="*, Auto">
                        <Label Grid.Column="0" Text="TOTAL:" FontAttributes="Bold" TextColor="#F0F0F0" FontSize="19"/>
                        <Label x:Name="lblTicketTotal" Grid.Column="1" Text="$0.00" FontAttributes="Bold" TextColor="#4CAF50" FontSize="22"/>
                    </Grid>

                    <Button Text="Cerrar Ticket" BackgroundColor="#141414" TextColor="#E0E0E0" FontAttributes="Bold" CornerRadius="16" HeightRequest="50" Margin="0,16,0,0" BorderWidth="1" BorderColor="#252525" Clicked="OnCerrarTicketClicked"/>
                    <Button x:Name="btnCancelarPedido" Text="Cancelar este Pedido" BackgroundColor="#fc4b08" TextColor="White" FontAttributes="Bold" CornerRadius="16" HeightRequest="50" Margin="0,10,0,0" Clicked="OnCancelarPedidoClienteClicked"/>
                </VerticalStackLayout>
            </Border>
        </Grid>
    </Grid>
</ContentPage>
<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:AppCenaduria.Views"
             x:Class="AppCenaduria.Views.AltaMenu"
             Title="Gestión de Menú"
             BackgroundColor="#0A0A0A">

    <ContentPage.Resources>
        <ResourceDictionary>
            <local:BoolToDisponibilidadConverter x:Key="BoolToDisponibilidadConverter" />
            <local:BoolToColorConverter x:Key="BoolToColorConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto, *">
        <ScrollView x:Name="mainScroll" Grid.Row="0" Grid.RowSpan="2">
            <VerticalStackLayout Padding="0" Spacing="0">

                <!-- ══════════════════════════════════════ -->
                <!--          HEADER HERO SECTION           -->
                <!-- ══════════════════════════════════════ -->
                <Border StrokeThickness="0" BackgroundColor="#111111" Padding="28,34,28,26">
                    <Border.StrokeShape><RoundRectangle CornerRadius="0,0,30,30"/></Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="0,10" Radius="24" Opacity="0.45"/>
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="6">
                        <!-- Icon + Title -->
                        <HorizontalStackLayout HorizontalOptions="Center" Spacing="10">
                            <Border StrokeThickness="0" BackgroundColor="#1C1206" WidthRequest="44" HeightRequest="44">
                                <Border.StrokeShape><RoundRectangle CornerRadius="14"/></Border.StrokeShape>
                                <Border.Shadow>
                                    <Shadow Brush="#fc4b08" Offset="0,0" Radius="10" Opacity="0.2"/>
                                </Border.Shadow>
                                <Label Text="⚙️" FontSize="19" HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                            <Label x:Name="lblTituloFormulario" Text="Nuevo Platillo" 
                                   FontSize="28" FontAttributes="Bold" TextColor="#F5F5F5" 
                                   VerticalOptions="Center" CharacterSpacing="0.5"/>
                        </HorizontalStackLayout>
                        <Label Text="Administra el catálogo de tu cenaduría" 
                               TextColor="#666666" FontSize="13" HorizontalOptions="Center"/>
                        <BoxView HeightRequest="3" Color="#fc4b08" WidthRequest="50" 
                                 HorizontalOptions="Center" Margin="0,8,0,0">
                            <BoxView.Shadow>
                                <Shadow Brush="#fc4b08" Offset="0,0" Radius="10" Opacity="0.5"/>
                            </BoxView.Shadow>
                        </BoxView>
                    </VerticalStackLayout>
                </Border>

                <VerticalStackLayout Padding="18,22,18,0" Spacing="16">

                    <!-- ══════════════════════════════════════ -->
                    <!--         CARD: DATOS PRINCIPALES       -->
                    <!-- ══════════════════════════════════════ -->
                    <Border StrokeThickness="1" Stroke="#1E1E1E" BackgroundColor="#111111" Padding="24,22">
                        <Border.StrokeShape><RoundRectangle CornerRadius="22"/></Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="Black" Offset="0,6" Radius="20" Opacity="0.35"/>
                        </Border.Shadow>
                        <VerticalStackLayout Spacing="20">
                            <!-- Section label -->
                            <HorizontalStackLayout Spacing="8">
                                <BoxView WidthRequest="4" HeightRequest="16" Color="#fc4b08" 
                                         VerticalOptions="Center">

                                </BoxView>
                                <Label Text="INFORMACIÓN DEL PLATILLO" TextColor="#888888" FontSize="11" 
                                       FontAttributes="Bold" CharacterSpacing="1" VerticalOptions="Center"/>
                            </HorizontalStackLayout>

                            <!-- Name -->
                            <VerticalStackLayout Spacing="8">
                                <HorizontalStackLayout Spacing="6">
                                    <Label Text="🏷️" FontSize="11"/>
                                    <Label Text="Nombre" TextColor="#AAAAAA" FontSize="12" FontAttributes="Bold"/>
                                </HorizontalStackLayout>
                                <Border StrokeThickness="1" Stroke="#252525" BackgroundColor="#0D0D0D" 
                                        Padding="16,0" HeightRequest="52">
                                    <Border.StrokeShape><RoundRectangle CornerRadius="14"/></Border.StrokeShape>
                                    <Entry x:Name="txtNombre" Placeholder="Ej. Tacos Dorados de Pollo" 
                                           PlaceholderColor="#444444" TextColor="White" 
                                           BackgroundColor="Transparent" FontSize="15"/>
                                </Border>
                            </VerticalStackLayout>

                            <!-- Description -->
                            <VerticalStackLayout Spacing="8">
                                <HorizontalStackLayout Spacing="6">
                                    <Label Text="📝" FontSize="11"/>
                                    <Label Text="Descripción" TextColor="#AAAAAA" FontSize="12" FontAttributes="Bold"/>
                                </HorizontalStackLayout>
                                <Border StrokeThickness="1" Stroke="#252525" BackgroundColor="#0D0D0D" 
                                        Padding="16,12">
                                    <Border.StrokeShape><RoundRectangle CornerRadius="14"/></Border.StrokeShape>
                                    <Editor x:Name="txtDescripcion" Placeholder="Ej. Tortilla crujiente, pollo desmenuzado, lechuga, crema y salsa..." 
                                            PlaceholderColor="#444444" TextColor="White" 
                                            HeightRequest="85" BackgroundColor="Transparent" FontSize="14"/>
                                </Border>
                            </VerticalStackLayout>

                            <!-- Categoría -->
                            <VerticalStackLayout Spacing="8">
                                <HorizontalStackLayout Spacing="6">
                                    <Label Text="📂" FontSize="11"/>
                                    <Label Text="Categoría" TextColor="#AAAAAA" FontSize="12" FontAttributes="Bold"/>
                                </HorizontalStackLayout>
                                <Border StrokeThickness="1" Stroke="#252525" BackgroundColor="#0D0D0D" 
                                        Padding="16,0" HeightRequest="52">
                                    <Border.StrokeShape><RoundRectangle CornerRadius="14"/></Border.StrokeShape>
                                    <Picker x:Name="pickerCategoria" Title="Seleccione..." TextColor="White" TitleColor="#444444" BackgroundColor="Transparent">
                                        <Picker.Items>
                                            <x:String>Comidas</x:String>
                                            <x:String>Bebidas</x:String>
                                            <x:String>Postres</x:String>
                                        </Picker.Items>
                                    </Picker>
                                </Border>
                            </VerticalStackLayout>

                            <!-- Price & Availability -->
                            <Grid ColumnDefinitions="*,*" ColumnSpacing="14">
                                <VerticalStackLayout Grid.Column="0" Spacing="8">
                                    <HorizontalStackLayout Spacing="6">
                                        <Label Text="💰" FontSize="11"/>
                                        <Label Text="Precio" TextColor="#AAAAAA" FontSize="12" FontAttributes="Bold"/>
                                    </HorizontalStackLayout>
                                    <Border StrokeThickness="1" Stroke="#252525" BackgroundColor="#0D0D0D" 
                                            Padding="16,0" HeightRequest="52">
                                        <Border.StrokeShape><RoundRectangle CornerRadius="14"/></Border.StrokeShape>
                                        <Grid ColumnDefinitions="Auto, *">
                                            <Label Grid.Column="0" Text="$" TextColor="#fc4b08" FontSize="18" 
                                                   FontAttributes="Bold" VerticalOptions="Center" Margin="0,0,4,0"/>
                                            <Entry Grid.Column="1" x:Name="txtPrecio" Placeholder="0.00" 
                                                   Keyboard="Numeric" PlaceholderColor="#444444" 
                                                   TextColor="White" BackgroundColor="Transparent" FontSize="16"/>
                                        </Grid>
                                    </Border>
                                </VerticalStackLayout>

                                <VerticalStackLayout Grid.Column="1" Spacing="8">
                                    <Label Text="Disponibilidad" TextColor="#AAAAAA" FontSize="12" 
                                           FontAttributes="Bold" HorizontalOptions="Center"/>
                                    <Border StrokeThickness="1" Stroke="#252525" BackgroundColor="#0D0D0D" 
                                            Padding="12,0" HeightRequest="52" HorizontalOptions="Fill">
                                        <Border.StrokeShape><RoundRectangle CornerRadius="14"/></Border.StrokeShape>
                                        <HorizontalStackLayout HorizontalOptions="Center" Spacing="10" VerticalOptions="Center">
                                            <Switch x:Name="swDisponible" IsToggled="True" OnColor="#fc4b08" ThumbColor="White"/>
                                            <Label Text="Activo" TextColor="#4CAF50" FontSize="12" 
                                                   FontAttributes="Bold" VerticalOptions="Center"/>
                                        </HorizontalStackLayout>
                                    </Border>
                                </VerticalStackLayout>
                            </Grid>
                        </VerticalStackLayout>
                    </Border>

                    <!-- ══════════════════════════════════════ -->
                    <!--          CARD: FOTOGRAFÍA             -->
                    <!-- ══════════════════════════════════════ -->
                    <Border StrokeThickness="1" Stroke="#1E1E1E" BackgroundColor="#111111" Padding="24,22">
                        <Border.StrokeShape><RoundRectangle CornerRadius="22"/></Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="Black" Offset="0,6" Radius="20" Opacity="0.35"/>
                        </Border.Shadow>
                        <VerticalStackLayout Spacing="14">
                            <HorizontalStackLayout Spacing="8">
                                <BoxView WidthRequest="4" HeightRequest="16" Color="#fc4b08" VerticalOptions="Center">

                                </BoxView>
                                <Label Text="IMAGEN DEL PLATILLO" TextColor="#888888" FontSize="11" 
                                       FontAttributes="Bold" CharacterSpacing="1" VerticalOptions="Center"/>
                            </HorizontalStackLayout>

                            <Grid ColumnDefinitions="*, Auto" ColumnSpacing="10">
                                <Border Grid.Column="0" StrokeThickness="1" Stroke="#252525" 
                                        BackgroundColor="#0D0D0D" Padding="16,0" HeightRequest="52">
                                    <Border.StrokeShape><RoundRectangle CornerRadius="14"/></Border.StrokeShape>
                                    <Entry x:Name="txtFotoUrl" Placeholder="URL de la imagen..." 
                                           PlaceholderColor="#444444" TextColor="White" 
                                           BackgroundColor="Transparent" FontSize="14"/>
                                </Border>
                                <Border Grid.Column="1" StrokeThickness="0" BackgroundColor="#1C1206" 
                                        WidthRequest="52" HeightRequest="52">
                                    <Border.StrokeShape><RoundRectangle CornerRadius="14"/></Border.StrokeShape>
                                    <Border.Shadow>
                                        <Shadow Brush="#fc4b08" Offset="0,0" Radius="8" Opacity="0.15"/>
                                    </Border.Shadow>
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnSeleccionarFotoClicked"/>
                                    </Border.GestureRecognizers>
                                    <Label Text="📷" FontSize="22" HorizontalOptions="Center" VerticalOptions="Center"/>
                                </Border>
                            </Grid>

                            <!-- Preview with placeholder -->
                            <Border StrokeThickness="1" Stroke="#1E1E1E" BackgroundColor="#0D0D0D" 
                                    HeightRequest="220" IsVisible="False" x:Name="borderPreview">
                                <Border.StrokeShape><RoundRectangle CornerRadius="18"/></Border.StrokeShape>
                                <Border.Shadow>
                                    <Shadow Brush="Black" Offset="0,4" Radius="12" Opacity="0.3"/>
                                </Border.Shadow>
                                <Image x:Name="imgPreview" HeightRequest="220" Aspect="AspectFill">
                                    <Image.Clip>
                                        <RoundRectangleGeometry CornerRadius="18" Rect="0,0,400,220"/>
                                    </Image.Clip>
                                </Image>
                            </Border>
                        </VerticalStackLayout>
                    </Border>

                    <!-- ══════════════════════════════════════ -->
                    <!--          BOTONES ACCIÓN               -->
                    <!-- ══════════════════════════════════════ -->
                    <Grid ColumnDefinitions="*, *" ColumnSpacing="12" Margin="0,6,0,0">
                        <Button x:Name="btnCancelar" 
                                Grid.Column="0" 
                                Text="✕  Cancelar" 
                                Clicked="OnCancelarClicked"
                                BackgroundColor="#141414" 
                                TextColor="#999999" 
                                FontAttributes="Bold" 
                                FontSize="15"
                                CornerRadius="18" 
                                HeightRequest="56" 
                                BorderWidth="1" 
                                BorderColor="#252525"
                                IsVisible="False" />
                                
                        <Button x:Name="btnGuardar" 
                                Grid.Column="1" Grid.ColumnSpan="2"
                                Text="Guardar Platillo" 
                                Clicked="OnGuardarClicked"
                                BackgroundColor="#fc4b08" 
                                TextColor="White" 
                                FontAttributes="Bold" 
                                FontSize="16"
                                CornerRadius="18" 
                                HeightRequest="56"
                                CharacterSpacing="0.3">
                            <Button.Shadow>
                                <Shadow Brush="#fc4b08" Offset="0,6" Radius="22" Opacity="0.45"/>
                            </Button.Shadow>
                        </Button>
                    </Grid>

                    <!-- ══════════════════════════════════════ -->
                    <!--          SECCIÓN: CATÁLOGO            -->
                    <!-- ══════════════════════════════════════ -->
                    <VerticalStackLayout Spacing="0" Margin="0,20,0,0">
                        <!-- Decorative Divider -->
                        <Grid ColumnDefinitions="*, Auto, *" Margin="0,0,0,18">
                            <BoxView Grid.Column="0" HeightRequest="1" Color="#1E1E1E" VerticalOptions="Center"/>
                            <Border Grid.Column="1" StrokeThickness="0" BackgroundColor="#161616" 
                                    Padding="16,6" Margin="10,0">
                                <Border.StrokeShape><RoundRectangle CornerRadius="10"/></Border.StrokeShape>
                                <Label Text="CATÁLOGO" TextColor="#666666" FontSize="10" 
                                       FontAttributes="Bold" CharacterSpacing="2"/>
                            </Border>
                            <BoxView Grid.Column="2" HeightRequest="1" Color="#1E1E1E" VerticalOptions="Center"/>
                        </Grid>

                        <!-- Catalog Header -->
                        <HorizontalStackLayout Spacing="10" Margin="4,0,0,14">
                            <Border StrokeThickness="0" BackgroundColor="#1C1206" 
                                    WidthRequest="38" HeightRequest="38">
                                <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                                <Label Text="📋" FontSize="17" HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                            <Label Text="Platillos Registrados" FontSize="19" FontAttributes="Bold" 
                                   TextColor="#E0E0E0" VerticalOptions="Center" CharacterSpacing="0.3"/>
                        </HorizontalStackLayout>
                    </VerticalStackLayout>

                    <!-- ══ Lista de Platillos ══ -->
                    <CollectionView x:Name="listaMenu" Margin="0,0,0,40">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Border StrokeThickness="1" Stroke="#1A1A1A" BackgroundColor="#111111" 
                                        Margin="0,0,0,10" Padding="14">
                                    <Border.StrokeShape><RoundRectangle CornerRadius="20"/></Border.StrokeShape>
                                    <Border.Shadow>
                                        <Shadow Brush="Black" Offset="0,4" Radius="14" Opacity="0.35"/>
                                    </Border.Shadow>
                                    <Grid ColumnDefinitions="78, *, Auto" ColumnSpacing="14">
                                        
                                        <!-- Photo -->
                                        <Border Grid.Column="0" StrokeThickness="1" Stroke="#1E1E1E" 
                                                BackgroundColor="#0D0D0D" WidthRequest="72" HeightRequest="72">
                                            <Border.StrokeShape><RoundRectangle CornerRadius="16"/></Border.StrokeShape>
                                            <Image Source="{Binding FotografiaUrl}" Aspect="AspectFill" 
                                                   HeightRequest="72" WidthRequest="72">
                                                <Image.Clip>
                                                    <RoundRectangleGeometry CornerRadius="16" Rect="0,0,72,72"/>
                                                </Image.Clip>
                                            </Image>
                                        </Border>
                                        
                                        <!-- Data -->
                                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="5">
                                            <Label Text="{Binding Nombre}" FontSize="15" FontAttributes="Bold" 
                                                   TextColor="#F0F0F0" LineBreakMode="TailTruncation" MaxLines="1" CharacterSpacing="0.3"/>
                                            <Label Text="{Binding Precio, StringFormat='${0:F2}'}" FontSize="17" 
                                                   TextColor="#fc4b08" FontAttributes="Bold"/>
                                            <!-- Status badge -->
                                            <Border StrokeThickness="0" 
                                                    BackgroundColor="{Binding Disponible, Converter={StaticResource BoolToColorConverter}, ConverterParameter=bg}" 
                                                    Padding="10,4" HorizontalOptions="Start">
                                                <Border.StrokeShape><RoundRectangle CornerRadius="8"/></Border.StrokeShape>
                                                <Label Text="{Binding Disponible, Converter={StaticResource BoolToDisponibilidadConverter}}" 
                                                       FontSize="10" FontAttributes="Bold"
                                                       TextColor="{Binding Disponible, Converter={StaticResource BoolToColorConverter}}"/>
                                            </Border>
                                        </VerticalStackLayout>
                                        
                                        <!-- Actions -->
                                        <VerticalStackLayout Grid.Column="2" Spacing="8" VerticalOptions="Center">
                                            <Border StrokeThickness="1" Stroke="#1A2A3D" BackgroundColor="#0D1520" 
                                                    WidthRequest="44" HeightRequest="44">
                                                <Border.StrokeShape><RoundRectangle CornerRadius="14"/></Border.StrokeShape>
                                                <Border.Shadow>
                                                    <Shadow Brush="Black" Offset="0,2" Radius="6" Opacity="0.2"/>
                                                </Border.Shadow>
                                                <Border.GestureRecognizers>
                                                    <TapGestureRecognizer Tapped="OnEditarClicked" CommandParameter="{Binding .}"/>
                                                </Border.GestureRecognizers>
                                                <Label Text="✏️" FontSize="17" HorizontalOptions="Center" VerticalOptions="Center"/>
                                            </Border>
                                            <Border StrokeThickness="1" Stroke="#3D1A1A" BackgroundColor="#200D0D" 
                                                    WidthRequest="44" HeightRequest="44">
                                                <Border.StrokeShape><RoundRectangle CornerRadius="14"/></Border.StrokeShape>
                                                <Border.Shadow>
                                                    <Shadow Brush="Black" Offset="0,2" Radius="6" Opacity="0.2"/>
                                                </Border.Shadow>
                                                <Border.GestureRecognizers>
                                                    <TapGestureRecognizer Tapped="OnEliminarClicked" CommandParameter="{Binding .}"/>
                                                </Border.GestureRecognizers>
                                                <Label Text="🗑" FontSize="17" HorizontalOptions="Center" VerticalOptions="Center"/>
                                            </Border>
                                        </VerticalStackLayout>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>

                        <CollectionView.EmptyView>
                            <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="12" Margin="0,30,0,40">
                                <Border StrokeThickness="1" Stroke="#1E1E1E" BackgroundColor="#111111" 
                                        WidthRequest="80" HeightRequest="80" HorizontalOptions="Center">
                                    <Border.StrokeShape><RoundRectangle CornerRadius="24"/></Border.StrokeShape>
                                    <Border.Shadow>
                                        <Shadow Brush="Black" Offset="0,4" Radius="12" Opacity="0.3"/>
                                    </Border.Shadow>
                                    <Label Text="🍽️" FontSize="32" HorizontalOptions="Center" VerticalOptions="Center"/>
                                </Border>
                                <Label Text="Sin platillos registrados" TextColor="#555555" FontSize="16" 
                                       FontAttributes="Bold" HorizontalOptions="Center"/>
                                <Label Text="Agrega tu primer platillo al catálogo" TextColor="#333333" FontSize="12" HorizontalOptions="Center"/>
                            </VerticalStackLayout>
                        </CollectionView.EmptyView>
                    </CollectionView>

                </VerticalStackLayout>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
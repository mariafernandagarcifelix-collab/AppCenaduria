<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AppCenaduria.Views.GestionPedidos"
             Title="Monitor de Cocina"
             BackgroundColor="#0A0A0A">

    <Grid RowDefinitions="Auto, *">

        <!-- ══ Header ══ -->
        <Border Grid.Row="0" StrokeThickness="0" BackgroundColor="#111111" Padding="24,28,24,20">
            <Border.StrokeShape><RoundRectangle CornerRadius="0,0,28,28"/></Border.StrokeShape>
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,8" Radius="20" Opacity="0.4"/>
            </Border.Shadow>
            <VerticalStackLayout Spacing="6">
                <HorizontalStackLayout HorizontalOptions="Center" Spacing="10">
                    <Border StrokeThickness="0" BackgroundColor="#1C1206" WidthRequest="38" HeightRequest="38">
                        <Border.StrokeShape><RoundRectangle CornerRadius="10"/></Border.StrokeShape>
                        <Label Text="🔥" FontSize="16" HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>
                    <Label Text="Pedidos Activos" FontSize="26" FontAttributes="Bold" TextColor="#F5F5F5" VerticalOptions="Center"/>
                </HorizontalStackLayout>
                <Label Text="Despacha las órdenes de la cenaduría" TextColor="#555555" FontSize="13" HorizontalOptions="Center"/>
                <BoxView HeightRequest="3" Color="#fc4b08" WidthRequest="40" HorizontalOptions="Center" Margin="0,6,0,0">
                    <BoxView.Shadow>
                        <Shadow Brush="#fc4b08" Offset="0,0" Radius="8" Opacity="0.5"/>
                    </BoxView.Shadow>
                </BoxView>
            </VerticalStackLayout>
        </Border>

        <!-- ══ Lista de Pedidos ══ -->
        <CollectionView x:Name="listaPedidos" Grid.Row="1" Margin="16,14,16,16">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border StrokeThickness="1" Stroke="#1E1E1E" BackgroundColor="#111111" 
                            Margin="0,0,0,14" Padding="0">
                        <Border.StrokeShape><RoundRectangle CornerRadius="18"/></Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="Black" Offset="0,4" Radius="12" Opacity="0.3"/>
                        </Border.Shadow>
                        <Grid ColumnDefinitions="6, *">

                            <!-- Barra lateral de color por tipo -->
                            <BoxView Grid.Column="0">
                                <BoxView.Triggers>
                                    <DataTrigger TargetType="BoxView" Binding="{Binding TipoEntrega}" Value="Comedor">
                                        <Setter Property="Color" Value="#4CAF50"/>
                                    </DataTrigger>
                                    <DataTrigger TargetType="BoxView" Binding="{Binding TipoEntrega}" Value="Domicilio">
                                        <Setter Property="Color" Value="#F44336"/>
                                    </DataTrigger>
                                    <DataTrigger TargetType="BoxView" Binding="{Binding TipoEntrega}" Value="Local">
                                        <Setter Property="Color" Value="#2196F3"/>
                                    </DataTrigger>
                                    <DataTrigger TargetType="BoxView" Binding="{Binding TipoEntrega}" Value="Para Llevar">
                                        <Setter Property="Color" Value="#2196F3"/>
                                    </DataTrigger>
                                </BoxView.Triggers>
                            </BoxView>

                            <!-- Contenido -->
                            <Grid Grid.Column="1" RowDefinitions="Auto, Auto, Auto" 
                                  ColumnDefinitions="*, Auto" RowSpacing="12" Padding="18">

                                <!-- Folio -->
                                <Label Grid.Row="0" Grid.Column="0" 
                                       Text="{Binding Folio, StringFormat='Orden #{0}'}" 
                                       FontSize="17" TextColor="#F0F0F0" FontAttributes="Bold"/>

                                <!-- Badge de estado -->
                                <Border Grid.Row="0" Grid.Column="1" StrokeThickness="0" 
                                        BackgroundColor="#0D2010" Padding="10,5">
                                    <Border.StrokeShape><RoundRectangle CornerRadius="8"/></Border.StrokeShape>
                                    <Label Text="{Binding Estado}" TextColor="#4CAF50" FontSize="11" FontAttributes="Bold"/>
                                </Border>

                                <!-- Detalles -->
                                <VerticalStackLayout Grid.Row="1" Grid.ColumnSpan="2" Spacing="6">
                                    <Label Text="{Binding Total, StringFormat='Total: ${0:F2}'}" 
                                           FontSize="22" FontAttributes="Bold" TextColor="#F5F5F5"/>
                                    <HorizontalStackLayout Spacing="8">
                                        <Border StrokeThickness="0" BackgroundColor="#1A1A1A" WidthRequest="22" HeightRequest="22">
                                            <Border.StrokeShape><RoundRectangle CornerRadius="6"/></Border.StrokeShape>
                                            <Label Text="👤" FontSize="12" HorizontalOptions="Center" VerticalOptions="Center"/>
                                        </Border>
                                        <Label Text="{Binding NombreCliente}" FontSize="14" TextColor="#fc4b08" FontAttributes="Bold" VerticalOptions="Center"/>
                                    </HorizontalStackLayout>
                                    
                                    <BoxView HeightRequest="1" Color="#1E1E1E" Margin="0,4"/>
                                    
                                    <HorizontalStackLayout Spacing="16">
                                        <Label Text="{Binding TipoEntrega, StringFormat='📦 {0}'}" FontSize="12" TextColor="#777777" FontAttributes="Bold"/>
                                        <Label Text="{Binding TipoPago, StringFormat='💳 {0}'}" FontSize="12" TextColor="#777777" FontAttributes="Bold"/>
                                    </HorizontalStackLayout>
                                </VerticalStackLayout>

                                <!-- Botón -->
                                <Button Grid.Row="2" Grid.ColumnSpan="2" 
                                        Text="Actualizar Estado  →" 
                                        BackgroundColor="#141E2A" 
                                        TextColor="#64B5F6" 
                                        FontAttributes="Bold" 
                                        FontSize="14"
                                        CornerRadius="14" 
                                        HeightRequest="48"
                                        Margin="0,8,0,0"
                                        BorderWidth="1"
                                        BorderColor="#1A2A3D"
                                        CommandParameter="{Binding .}"
                                        Clicked="OnCambiarEstadoClicked"/>
                            </Grid>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>

            <CollectionView.EmptyView>
                <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="10" Margin="0,60,0,0">
                    <Border StrokeThickness="1" Stroke="#1E1E1E" BackgroundColor="#111111" WidthRequest="70" HeightRequest="70" HorizontalOptions="Center">
                        <Border.StrokeShape><RoundRectangle CornerRadius="20"/></Border.StrokeShape>
                        <Label Text="🙌" FontSize="28" HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>
                    <Label Text="Sin pedidos pendientes" TextColor="#555555" FontSize="16" FontAttributes="Bold" HorizontalOptions="Center"/>
                    <Label Text="¡Todo al día!" TextColor="#333333" FontSize="12" HorizontalOptions="Center"/>
                </VerticalStackLayout>
            </CollectionView.EmptyView>
        </CollectionView>
    </Grid>
</ContentPage>
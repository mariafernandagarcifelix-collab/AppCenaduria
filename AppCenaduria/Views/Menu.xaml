<?xml version="1.0" encoding="utf-8" ?>
<FlyoutPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AppCenaduria.Views.Menu"
            FlyoutLayoutBehavior="Popover">

    <FlyoutPage.Flyout>
        <ContentPage Title="Menú">
            <Grid RowDefinitions="Auto, *, Auto" BackgroundColor="#0A0A0A">

                <!-- ══ Header del Menú Lateral ══ -->
                <Border Grid.Row="0" StrokeThickness="0" BackgroundColor="#111111" Padding="24,44,24,22">
                    <Border.StrokeShape><RoundRectangle CornerRadius="0,0,20,20"/></Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="0,6" Radius="14" Opacity="0.3"/>
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="6">
                        <!-- Logo -->
                        <Border StrokeThickness="2" Stroke="#fc4b08" BackgroundColor="#0F0F0F"
                                HorizontalOptions="Start" WidthRequest="52" HeightRequest="52" Margin="0,0,0,10">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="16"/>
                            </Border.StrokeShape>
                            <Border.Shadow>
                                <Shadow Brush="#fc4b08" Offset="0,0" Radius="14" Opacity="0.25"/>
                            </Border.Shadow>
                            <Image Source="dotnet_bot.png" HeightRequest="32" WidthRequest="32"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <Label Text="Cenaduría" FontSize="22" TextColor="#fc4b08" FontAttributes="Bold" CharacterSpacing="1.5"/>
                        <Label Text="El Parquesito" FontSize="13" TextColor="#666666" CharacterSpacing="1"/>
                    </VerticalStackLayout>
                </Border>

                <!-- ══ Navegación Principal ══ -->
                <ScrollView Grid.Row="1">
                    <VerticalStackLayout Padding="12,8" Spacing="2">

                        <!-- Sección Cliente -->
                        <Label Text="NAVEGACIÓN" TextColor="#555555" FontSize="10" FontAttributes="Bold" 
                               Margin="14,14,0,10" CharacterSpacing="2"/>

                        <Border StrokeThickness="0" BackgroundColor="Transparent" Padding="14,13" HorizontalOptions="Fill">
                            <Border.StrokeShape><RoundRectangle CornerRadius="14"/></Border.StrokeShape>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnPerfilClicked"/>
                            </Border.GestureRecognizers>
                            <HorizontalStackLayout Spacing="14">
                                <Border StrokeThickness="1" Stroke="#1E1E1E" BackgroundColor="#0F0F0F" WidthRequest="38" HeightRequest="38">
                                    <Border.StrokeShape><RoundRectangle CornerRadius="11"/></Border.StrokeShape>
                                    <Label Text="👤" FontSize="16" HorizontalOptions="Center" VerticalOptions="Center"/>
                                </Border>
                                <Label Text="Mi Perfil" TextColor="#E0E0E0" FontSize="15" VerticalOptions="Center"/>
                            </HorizontalStackLayout>
                        </Border>

                        <Border StrokeThickness="0" BackgroundColor="Transparent" Padding="14,13" HorizontalOptions="Fill">
                            <Border.StrokeShape><RoundRectangle CornerRadius="14"/></Border.StrokeShape>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnVerMenuClicked"/>
                            </Border.GestureRecognizers>
                            <HorizontalStackLayout Spacing="14">
                                <Border StrokeThickness="1" Stroke="#1E1E1E" BackgroundColor="#0F0F0F" WidthRequest="38" HeightRequest="38">
                                    <Border.StrokeShape><RoundRectangle CornerRadius="11"/></Border.StrokeShape>
                                    <Label Text="🍽️" FontSize="16" HorizontalOptions="Center" VerticalOptions="Center"/>
                                </Border>
                                <Label Text="Ver Menú" TextColor="#E0E0E0" FontSize="15" VerticalOptions="Center"/>
                            </HorizontalStackLayout>
                        </Border>

                        <Border StrokeThickness="0" BackgroundColor="Transparent" Padding="14,13" HorizontalOptions="Fill">
                            <Border.StrokeShape><RoundRectangle CornerRadius="14"/></Border.StrokeShape>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnMiCarritoClicked"/>
                            </Border.GestureRecognizers>
                            <HorizontalStackLayout Spacing="14">
                                <Border StrokeThickness="1" Stroke="#1E1E1E" BackgroundColor="#0F0F0F" WidthRequest="38" HeightRequest="38">
                                    <Border.StrokeShape><RoundRectangle CornerRadius="11"/></Border.StrokeShape>
                                    <Label Text="🛒" FontSize="16" HorizontalOptions="Center" VerticalOptions="Center"/>
                                </Border>
                                <Label Text="Mi Carrito" TextColor="#E0E0E0" FontSize="15" VerticalOptions="Center"/>
                            </HorizontalStackLayout>
                        </Border>

                        <Border StrokeThickness="0" BackgroundColor="Transparent" Padding="14,13" HorizontalOptions="Fill">
                            <Border.StrokeShape><RoundRectangle CornerRadius="14"/></Border.StrokeShape>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnHistorialClicked"/>
                            </Border.GestureRecognizers>
                            <HorizontalStackLayout Spacing="14">
                                <Border StrokeThickness="1" Stroke="#1E1E1E" BackgroundColor="#0F0F0F" WidthRequest="38" HeightRequest="38">
                                    <Border.StrokeShape><RoundRectangle CornerRadius="11"/></Border.StrokeShape>
                                    <Label Text="📜" FontSize="16" HorizontalOptions="Center" VerticalOptions="Center"/>
                                </Border>
                                <Label Text="Historial Pedidos" TextColor="#E0E0E0" FontSize="15" VerticalOptions="Center"/>
                            </HorizontalStackLayout>
                        </Border>

                        <!-- ══ Sección Admin ══ -->
                        <VerticalStackLayout x:Name="seccionAdmin" Spacing="2" Margin="0,6,0,0">
                            <BoxView HeightRequest="1" Color="#1A1A1A" Margin="14,6"/>
                            <Label Text="ADMINISTRACIÓN" TextColor="#fc4b08" FontSize="10" FontAttributes="Bold" 
                                   Margin="14,8,0,10" CharacterSpacing="2"/>

                            <Border StrokeThickness="0" BackgroundColor="Transparent" Padding="14,13" HorizontalOptions="Fill">
                                <Border.StrokeShape><RoundRectangle CornerRadius="14"/></Border.StrokeShape>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnAltaMenuClicked"/>
                                </Border.GestureRecognizers>
                                <HorizontalStackLayout Spacing="14">
                                    <Border StrokeThickness="1" Stroke="#261006" BackgroundColor="#140A03" WidthRequest="38" HeightRequest="38">
                                        <Border.StrokeShape><RoundRectangle CornerRadius="11"/></Border.StrokeShape>
                                        <Label Text="⚙️" FontSize="16" HorizontalOptions="Center" VerticalOptions="Center"/>
                                    </Border>
                                    <Label Text="Gestión de Menú" TextColor="#E0E0E0" FontSize="15" VerticalOptions="Center"/>
                                </HorizontalStackLayout>
                            </Border>

                            <Border StrokeThickness="0" BackgroundColor="Transparent" Padding="14,13" HorizontalOptions="Fill">
                                <Border.StrokeShape><RoundRectangle CornerRadius="14"/></Border.StrokeShape>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnGestionPedidosClicked"/>
                                </Border.GestureRecognizers>
                                <HorizontalStackLayout Spacing="14">
                                    <Border StrokeThickness="1" Stroke="#261006" BackgroundColor="#140A03" WidthRequest="38" HeightRequest="38">
                                        <Border.StrokeShape><RoundRectangle CornerRadius="11"/></Border.StrokeShape>
                                        <Label Text="📋" FontSize="16" HorizontalOptions="Center" VerticalOptions="Center"/>
                                    </Border>
                                    <Label Text="Gestión de Pedidos" TextColor="#E0E0E0" FontSize="15" VerticalOptions="Center"/>
                                </HorizontalStackLayout>
                            </Border>

                            <Border StrokeThickness="0" BackgroundColor="Transparent" Padding="14,13" HorizontalOptions="Fill">
                                <Border.StrokeShape><RoundRectangle CornerRadius="14"/></Border.StrokeShape>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnReportesClicked"/>
                                </Border.GestureRecognizers>
                                <HorizontalStackLayout Spacing="14">
                                    <Border StrokeThickness="1" Stroke="#261006" BackgroundColor="#140A03" WidthRequest="38" HeightRequest="38">
                                        <Border.StrokeShape><RoundRectangle CornerRadius="11"/></Border.StrokeShape>
                                        <Label Text="📊" FontSize="16" HorizontalOptions="Center" VerticalOptions="Center"/>
                                    </Border>
                                    <Label Text="Reportes" TextColor="#E0E0E0" FontSize="15" VerticalOptions="Center"/>
                                </HorizontalStackLayout>
                            </Border>

                            <Border StrokeThickness="0" BackgroundColor="Transparent" Padding="14,13" HorizontalOptions="Fill">
                                <Border.StrokeShape><RoundRectangle CornerRadius="14"/></Border.StrokeShape>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnHistorialVentasClicked"/>
                                </Border.GestureRecognizers>
                                <HorizontalStackLayout Spacing="14">
                                    <Border StrokeThickness="1" Stroke="#261006" BackgroundColor="#140A03" WidthRequest="38" HeightRequest="38">
                                        <Border.StrokeShape><RoundRectangle CornerRadius="11"/></Border.StrokeShape>
                                        <Label Text="📈" FontSize="16" HorizontalOptions="Center" VerticalOptions="Center"/>
                                    </Border>
                                    <Label Text="Historial de Ventas" TextColor="#E0E0E0" FontSize="15" VerticalOptions="Center"/>
                                </HorizontalStackLayout>
                            </Border>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </ScrollView>

                <!-- ══ Footer ══ -->
                <Border Grid.Row="2" StrokeThickness="0" BackgroundColor="Transparent" 
                        Padding="24,16" Margin="0,0,0,24">
                    <VerticalStackLayout Spacing="10">
                        <BoxView HeightRequest="1" Color="#1A1A1A"/>
                        <HorizontalStackLayout Spacing="8">
                            <Label Text="🚪" FontSize="13" VerticalOptions="Center"/>
                            <Label Text="Cerrar Sesión" TextColor="#555555" FontSize="13" VerticalOptions="Center"/>
                        </HorizontalStackLayout>
                    </VerticalStackLayout>
                </Border>

            </Grid>
        </ContentPage>
    </FlyoutPage.Flyout>

    <FlyoutPage.Detail>
        <NavigationPage>
            <x:Arguments>
                <ContentPage Title="Inicio" BackgroundColor="#0A0A0A">
                    <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="18" Padding="30">
                        
                        <!-- Welcome icon -->
                        <Border StrokeThickness="2" Stroke="#fc4b08" BackgroundColor="#0F0F0F"
                                HorizontalOptions="Center" WidthRequest="96" HeightRequest="96">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="48"/>
                            </Border.StrokeShape>
                            <Border.Shadow>
                                <Shadow Brush="#fc4b08" Offset="0,0" Radius="28" Opacity="0.25"/>
                            </Border.Shadow>
                            <Label Text="🌮" FontSize="42" HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>

                        <Label Text="¡Bienvenido!" 
                               FontSize="30" FontAttributes="Bold" 
                               TextColor="#F5F5F5" HorizontalOptions="Center" 
                               HorizontalTextAlignment="Center" CharacterSpacing="1"/>

                        <BoxView HeightRequest="3" Color="#fc4b08" WidthRequest="40" HorizontalOptions="Center">
                            <BoxView.Shadow>
                                <Shadow Brush="#fc4b08" Offset="0,0" Radius="8" Opacity="0.5"/>
                            </BoxView.Shadow>
                        </BoxView>

                        <Label Text="Desliza desde el borde izquierdo&#x0a;o toca el menú para comenzar" 
                               TextColor="#555555" FontSize="14"
                               HorizontalOptions="Center" HorizontalTextAlignment="Center"
                               LineHeight="1.5"/>

                        <!-- Tarjetas de acceso rápido -->
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="14" Margin="0,24,0,0">
                            <Border Grid.Column="0" StrokeThickness="1" Stroke="#1E1E1E" BackgroundColor="#111111" Padding="22,18">
                                <Border.StrokeShape><RoundRectangle CornerRadius="18"/></Border.StrokeShape>
                                <Border.Shadow>
                                    <Shadow Brush="Black" Offset="0,4" Radius="12" Opacity="0.3"/>
                                </Border.Shadow>
                                <VerticalStackLayout Spacing="10" HorizontalOptions="Center">
                                    <Label Text="🍽️" FontSize="28" HorizontalOptions="Center"/>
                                    <Label Text="Ver Menú" TextColor="#E0E0E0" FontSize="13" FontAttributes="Bold" HorizontalOptions="Center"/>
                                </VerticalStackLayout>
                            </Border>
                            <Border Grid.Column="1" StrokeThickness="1" Stroke="#1E1E1E" BackgroundColor="#111111" Padding="22,18">
                                <Border.StrokeShape><RoundRectangle CornerRadius="18"/></Border.StrokeShape>
                                <Border.Shadow>
                                    <Shadow Brush="Black" Offset="0,4" Radius="12" Opacity="0.3"/>
                                </Border.Shadow>
                                <VerticalStackLayout Spacing="10" HorizontalOptions="Center">
                                    <Label Text="🛒" FontSize="28" HorizontalOptions="Center"/>
                                    <Label Text="Mi Carrito" TextColor="#E0E0E0" FontSize="13" FontAttributes="Bold" HorizontalOptions="Center"/>
                                </VerticalStackLayout>
                            </Border>
                        </Grid>
                    </VerticalStackLayout>
                </ContentPage>
            </x:Arguments>
        </NavigationPage>
    </FlyoutPage.Detail>

</FlyoutPage>
<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AppCenaduria.Views.HistorialVentas"
             Title="Corte de Caja"
             BackgroundColor="#0A0A0A">

    <Grid RowDefinitions="Auto, Auto, Auto, *" Padding="0">

        <!-- ══ Header ══ -->
        <Border Grid.Row="0" StrokeThickness="0" BackgroundColor="#111111" Padding="24,28,24,18">
            <Border.StrokeShape><RoundRectangle CornerRadius="0,0,28,28"/></Border.StrokeShape>
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,8" Radius="20" Opacity="0.4"/>
            </Border.Shadow>
            <VerticalStackLayout Spacing="6">
                <HorizontalStackLayout HorizontalOptions="Center" Spacing="10">
                    <Border StrokeThickness="0" BackgroundColor="#140A03" WidthRequest="38" HeightRequest="38">
                        <Border.StrokeShape><RoundRectangle CornerRadius="10"/></Border.StrokeShape>
                        <Label Text="📈" FontSize="16" HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>
                    <Label Text="Historial de Ventas" FontSize="24" FontAttributes="Bold" TextColor="#F5F5F5" VerticalOptions="Center"/>
                </HorizontalStackLayout>
                <BoxView HeightRequest="3" Color="#fc4b08" WidthRequest="40" HorizontalOptions="Center" Margin="0,6,0,0">
                    <BoxView.Shadow>
                        <Shadow Brush="#fc4b08" Offset="0,0" Radius="8" Opacity="0.5"/>
                    </BoxView.Shadow>
                </BoxView>
            </VerticalStackLayout>
        </Border>

        <!-- ══ Filtros ══ -->
        <VerticalStackLayout Grid.Row="1" Spacing="10" Padding="16,14,16,0">
            <!-- Buscador -->
            <Border StrokeThickness="1" Stroke="#1E1E1E" BackgroundColor="#111111" Padding="0" HeightRequest="48">
                <Border.StrokeShape><RoundRectangle CornerRadius="14"/></Border.StrokeShape>
                <SearchBar x:Name="sbBuscador" 
                           Placeholder="Buscar mesa, nombre o folio..." 
                           PlaceholderColor="#444444" TextColor="White"
                           BackgroundColor="Transparent" TextChanged="OnFiltrosCambiados"/>
            </Border>

            <!-- Toggle de fechas -->
            <VerticalStackLayout Spacing="8">
                <HorizontalStackLayout Spacing="10">
                    <Switch x:Name="swUsarFechas" IsToggled="False" Toggled="OnSwitchFechasToggled" OnColor="#fc4b08" ThumbColor="White"/>
                    <Label Text="Filtrar por rango de fechas" TextColor="#666666" VerticalOptions="Center" FontSize="13"/>
                </HorizontalStackLayout>

                <Grid x:Name="contenedorFechas" ColumnDefinitions="*, *" ColumnSpacing="10" IsEnabled="False" Opacity="0.4">
                    <Border Grid.Column="0" StrokeThickness="1" Stroke="#1E1E1E" BackgroundColor="#111111" Padding="10,6">
                        <Border.StrokeShape><RoundRectangle CornerRadius="14"/></Border.StrokeShape>
                        <VerticalStackLayout>
                            <Label Text="Desde:" TextColor="#555555" FontSize="10"/>
                            <DatePicker x:Name="dpInicio" BackgroundColor="Transparent" TextColor="White" Format="dd/MM/yyyy" DateSelected="OnFiltrosCambiados"/>
                        </VerticalStackLayout>
                    </Border>
                    <Border Grid.Column="1" StrokeThickness="1" Stroke="#1E1E1E" BackgroundColor="#111111" Padding="10,6">
                        <Border.StrokeShape><RoundRectangle CornerRadius="14"/></Border.StrokeShape>
                        <VerticalStackLayout>
                            <Label Text="Hasta:" TextColor="#555555" FontSize="10"/>
                            <DatePicker x:Name="dpFin" BackgroundColor="Transparent" TextColor="White" Format="dd/MM/yyyy" DateSelected="OnFiltrosCambiados"/>
                        </VerticalStackLayout>
                    </Border>
                </Grid>
            </VerticalStackLayout>
        </VerticalStackLayout>

        <!-- ══ Chips de Filtro ══ -->
        <ScrollView Grid.Row="2" Orientation="Horizontal" HorizontalScrollBarVisibility="Never" Margin="16,12,16,10">
            <HorizontalStackLayout Spacing="8">
                <Button Text="Todos" StyleId="Todos" Clicked="OnFiltroChipClicked" 
                        BackgroundColor="#fc4b08" TextColor="White" CornerRadius="12" 
                        HeightRequest="34" Padding="14,0" FontSize="12" FontAttributes="Bold"/>
                <Button Text="Efectivo" StyleId="Efectivo" Clicked="OnFiltroChipClicked" 
                        BackgroundColor="#1A1A1A" TextColor="#888888" CornerRadius="12" 
                        HeightRequest="34" Padding="14,0" FontSize="12" BorderWidth="1" BorderColor="#252525"/>
                <Button Text="Tarjeta" StyleId="Tarjeta" Clicked="OnFiltroChipClicked" 
                        BackgroundColor="#1A1A1A" TextColor="#888888" CornerRadius="12" 
                        HeightRequest="34" Padding="14,0" FontSize="12" BorderWidth="1" BorderColor="#252525"/>
                <Button Text="Comedor" StyleId="Comedor" Clicked="OnFiltroChipClicked" 
                        BackgroundColor="#1A1A1A" TextColor="#888888" CornerRadius="12" 
                        HeightRequest="34" Padding="14,0" FontSize="12" BorderWidth="1" BorderColor="#252525"/>
                <Button Text="Domicilio" StyleId="Domicilio" Clicked="OnFiltroChipClicked" 
                        BackgroundColor="#1A1A1A" TextColor="#888888" CornerRadius="12" 
                        HeightRequest="34" Padding="14,0" FontSize="12" BorderWidth="1" BorderColor="#252525"/>
            </HorizontalStackLayout>
        </ScrollView>

        <!-- ══ Lista de Ventas ══ -->
        <CollectionView Grid.Row="3" x:Name="listaHistorial" Margin="16,0,16,8">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border StrokeThickness="1" Stroke="#1A1A1A" BackgroundColor="#111111" 
                            Margin="0,0,0,10" Padding="0">
                        <Border.StrokeShape><RoundRectangle CornerRadius="16"/></Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="Black" Offset="0,4" Radius="10" Opacity="0.25"/>
                        </Border.Shadow>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnPedidoTapped" CommandParameter="{Binding .}"/>
                        </Border.GestureRecognizers>

                        <Grid ColumnDefinitions="5, *, Auto">

                            <!-- Barra lateral -->
                            <BoxView Grid.Column="0">
                                <BoxView.Triggers>
                                    <DataTrigger TargetType="BoxView" Binding="{Binding TipoEntrega}" Value="Comedor">
                                        <Setter Property="Color" Value="#4CAF50"/>
                                    </DataTrigger>
                                    <DataTrigger TargetType="BoxView" Binding="{Binding TipoEntrega}" Value="Domicilio">
                                        <Setter Property="Color" Value="#F44336"/>
                                    </DataTrigger>
                                    <DataTrigger TargetType="BoxView" Binding="{Binding TipoEntrega}" Value="Local">
                                        <Setter Property="Color" Value="#2196F3"/>
                                    </DataTrigger>
                                    <DataTrigger TargetType="BoxView" Binding="{Binding TipoEntrega}" Value="Para Llevar">
                                        <Setter Property="Color" Value="#2196F3"/>
                                    </DataTrigger>
                                </BoxView.Triggers>
                            </BoxView>

                            <!-- Info -->
                            <VerticalStackLayout Grid.Column="1" Padding="14,12" Spacing="3">
                                <Label Text="{Binding Folio, StringFormat='Orden #{0}'}" TextColor="#F0F0F0" FontAttributes="Bold" FontSize="14"/>
                                <Label Text="{Binding NombreCliente}" TextColor="#888888" FontSize="13" FontAttributes="Bold"/>
                                <Label Text="{Binding FechaPedido, StringFormat='{0:dd/MM/yyyy hh:mm tt}'}" TextColor="#444444" FontSize="10"/>
                            </VerticalStackLayout>

                            <!-- Total + Menú -->
                            <HorizontalStackLayout Grid.Column="2" VerticalOptions="Center" Spacing="6" Margin="0,0,10,0">
                                <Label Text="{Binding Total, StringFormat='${0:F2}'}" TextColor="#4CAF50" FontAttributes="Bold" FontSize="15" VerticalOptions="Center"/>

                                <Border StrokeThickness="1" Stroke="#252525" BackgroundColor="#0F0F0F" WidthRequest="34" HeightRequest="34" 
                                        VerticalOptions="Center">
                                    <Border.StrokeShape><RoundRectangle CornerRadius="10"/></Border.StrokeShape>
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnDotsTapped" CommandParameter="{Binding .}"/>
                                    </Border.GestureRecognizers>
                                    <Label Text="⋮" FontSize="18" TextColor="#666666" HorizontalOptions="Center" VerticalOptions="Center"/>
                                </Border>
                            </HorizontalStackLayout>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- ══ Modal Ticket ══ -->
        <Grid x:Name="modalTicket" Grid.RowSpan="4" IsVisible="False" BackgroundColor="#CC000000">
            <Border StrokeThickness="1" Stroke="#1E1E1E" BackgroundColor="#111111" 
                    WidthRequest="340" HorizontalOptions="Center" VerticalOptions="Center"
                    Padding="26">
                <Border.StrokeShape><RoundRectangle CornerRadius="24"/></Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="#fc4b08" Offset="0,0" Radius="30" Opacity="0.15"/>
                </Border.Shadow>
                <VerticalStackLayout Spacing="8">
                    <Label Text="CENADURÍA EL PARQUESITO" FontAttributes="Bold" FontSize="13" TextColor="#888888" HorizontalOptions="Center" CharacterSpacing="1.5"/>
                    <Label x:Name="lblTicketFolio" Text="Folio:" TextColor="#F0F0F0" FontAttributes="Bold" FontSize="18" HorizontalOptions="Center"/>
                    <BoxView HeightRequest="1" Color="#1E1E1E" Margin="0,4"/>
                    <Label x:Name="lblTicketCliente" Text="Cliente:" TextColor="#888888" FontSize="13"/>
                    <Label x:Name="lblTicketFecha" Text="Fecha:" TextColor="#888888" FontSize="13"/>
                    <Label x:Name="lblTicketTipo" Text="Tipo:" TextColor="#888888" FontSize="13"/>
                    <BoxView HeightRequest="1" Color="#1E1E1E" Margin="0,4"/>

                    <CollectionView x:Name="listaDetallesTicket" MaximumHeightRequest="200">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="Auto, *, Auto" Padding="0,5">
                                    <Label Grid.Column="0" Text="{Binding Cantidad, StringFormat='{0}x '}" TextColor="#666666" FontSize="13"/>
                                    <Label Grid.Column="1" Text="{Binding NombrePlatillo}" TextColor="#E0E0E0" FontSize="13" LineBreakMode="TailTruncation" Margin="5,0"/>
                                    <Label Grid.Column="2" Text="{Binding Subtotal, StringFormat='${0:F2}'}" TextColor="#E0E0E0" FontSize="13" FontAttributes="Bold"/>
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <BoxView HeightRequest="2" Color="#fc4b08" Margin="0,4">
                        <BoxView.Shadow>
                            <Shadow Brush="#fc4b08" Offset="0,0" Radius="6" Opacity="0.4"/>
                        </BoxView.Shadow>
                    </BoxView>
                    <Grid ColumnDefinitions="*, Auto">
                        <Label Grid.Column="0" Text="TOTAL" FontAttributes="Bold" TextColor="#888888" FontSize="14" CharacterSpacing="1"/>
                        <Label x:Name="lblTicketTotal" Grid.Column="1" Text="$0.00" FontAttributes="Bold" TextColor="#fc4b08" FontSize="20"/>
                    </Grid>
                    <Button Text="Cerrar" BackgroundColor="#fc4b08" TextColor="White" FontAttributes="Bold"
                            CornerRadius="14" HeightRequest="48" Margin="0,8,0,0" FontSize="15"
                            Clicked="OnCerrarTicketClicked">
                        <Button.Shadow>
                            <Shadow Brush="#fc4b08" Offset="0,4" Radius="14" Opacity="0.35"/>
                        </Button.Shadow>
                    </Button>
                </VerticalStackLayout>
            </Border>
        </Grid>
    </Grid>
</ContentPage>
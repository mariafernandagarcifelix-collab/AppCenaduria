<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AppCenaduria.Views.HistorialCliente"
             Title="Mis Pedidos"
             BackgroundColor="#0A0A0A">

    <Grid>
        <VerticalStackLayout Padding="0" Spacing="0">

            <!-- ══ Header ══ -->
            <Border StrokeThickness="0" BackgroundColor="#111111" Padding="24,30,24,22">
                <Border.StrokeShape><RoundRectangle CornerRadius="0,0,30,30"/></Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="Black" Offset="0,10" Radius="24" Opacity="0.45"/>
                </Border.Shadow>
                <VerticalStackLayout Spacing="6">
                    <HorizontalStackLayout HorizontalOptions="Center" Spacing="10">
                        <Border StrokeThickness="0" BackgroundColor="#1C1206" WidthRequest="42" HeightRequest="42">
                            <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                            <Border.Shadow>
                                <Shadow Brush="#fc4b08" Offset="0,0" Radius="10" Opacity="0.2"/>
                            </Border.Shadow>
                            <Label Text="🌮" FontSize="18" HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <Label Text="Tus Compras" FontSize="28" FontAttributes="Bold" TextColor="#F5F5F5" VerticalOptions="Center" CharacterSpacing="0.5"/>
                    </HorizontalStackLayout>
                    <Label Text="Sigue el trayecto de tus antojitos en tiempo real" TextColor="#555555" FontSize="13" HorizontalOptions="Center"/>
                    <BoxView HeightRequest="3" Color="#fc4b08" WidthRequest="44" HorizontalOptions="Center" Margin="0,6,0,0">
                        <BoxView.Shadow>
                            <Shadow Brush="#fc4b08" Offset="0,0" Radius="10" Opacity="0.5"/>
                        </BoxView.Shadow>
                    </BoxView>
                </VerticalStackLayout>
            </Border>

            <!-- ══ Orders List ══ -->
            <CollectionView x:Name="listaMisPedidos" Margin="16,16,16,0">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border StrokeThickness="1" Stroke="#1E1E1E" BackgroundColor="#111111" 
                                Margin="0,0,0,12" Padding="0">
                            <Border.StrokeShape><RoundRectangle CornerRadius="20"/></Border.StrokeShape>
                            <Border.Shadow>
                                <Shadow Brush="Black" Offset="0,4" Radius="14" Opacity="0.35"/>
                            </Border.Shadow>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnPedidoTapped" CommandParameter="{Binding .}"/>
                            </Border.GestureRecognizers>

                            <Grid ColumnDefinitions="6, *, Auto">
                                <!-- Status Bar -->
                                <Border Grid.Column="0" StrokeThickness="0">
                                    <Border.StrokeShape><RoundRectangle CornerRadius="20,0,0,20"/></Border.StrokeShape>
                                    <BoxView>
                                        <BoxView.Triggers>
                                            <DataTrigger TargetType="BoxView" Binding="{Binding Estado}" Value="En preparación">
                                                <Setter Property="Color" Value="#FF9800"/>
                                            </DataTrigger>
                                            <DataTrigger TargetType="BoxView" Binding="{Binding Estado}" Value="En proceso de entrega">
                                                <Setter Property="Color" Value="#2196F3"/>
                                            </DataTrigger>
                                            <DataTrigger TargetType="BoxView" Binding="{Binding Estado}" Value="Entregado">
                                                <Setter Property="Color" Value="#4CAF50"/>
                                            </DataTrigger>
                                            <DataTrigger TargetType="BoxView" Binding="{Binding Estado}" Value="Cancelado">
                                                <Setter Property="Color" Value="#F44336"/>
                                            </DataTrigger>
                                        </BoxView.Triggers>
                                    </BoxView>
                                </Border>

                                <!-- Info -->
                                <VerticalStackLayout Grid.Column="1" Padding="18,16" Spacing="5">
                                    <Label Text="{Binding Folio, StringFormat='Orden #{0}'}" TextColor="#F0F0F0" FontAttributes="Bold" FontSize="17" CharacterSpacing="0.3"/>
                                    <HorizontalStackLayout Spacing="6">
                                        <Label Text="🕐" FontSize="10"/>
                                        <Label Text="{Binding FechaPedido, StringFormat='{0:dd/MM/yyyy hh:mm tt}'}" TextColor="#666666" FontSize="11"/>
                                    </HorizontalStackLayout>
                                    <Border StrokeThickness="0" BackgroundColor="#1C1206" Padding="12,5" HorizontalOptions="Start" Margin="0,4,0,0">
                                        <Border.StrokeShape><RoundRectangle CornerRadius="10"/></Border.StrokeShape>
                                        <Label Text="{Binding Estado}" TextColor="#fc4b08" FontAttributes="Bold" FontSize="11"/>
                                    </Border>
                                </VerticalStackLayout>

                                <!-- Total -->
                                <Label Grid.Column="2" Text="{Binding Total, StringFormat='${0:F2}'}" 
                                       TextColor="#4CAF50" FontAttributes="Bold" FontSize="19" 
                                       VerticalOptions="Center" Margin="0,0,18,0"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>

                <CollectionView.EmptyView>
                    <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="12" Margin="0,60,0,0">
                        <Border StrokeThickness="1" Stroke="#1E1E1E" BackgroundColor="#111111" WidthRequest="80" HeightRequest="80" HorizontalOptions="Center">
                            <Border.StrokeShape><RoundRectangle CornerRadius="24"/></Border.StrokeShape>
                            <Border.Shadow>
                                <Shadow Brush="Black" Offset="0,4" Radius="12" Opacity="0.3"/>
                            </Border.Shadow>
                            <Label Text="🛒" FontSize="32" HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <Label Text="Aún no tienes pedidos" TextColor="#555555" FontSize="17" FontAttributes="Bold" HorizontalOptions="Center"/>
                        <Label Text="¡Explora el menú y haz tu primera compra!" TextColor="#333333" FontSize="13" HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </CollectionView.EmptyView>
            </CollectionView>
        </VerticalStackLayout>

        <!-- ══ Ticket Modal ══ -->
        <Grid x:Name="modalTicketCliente" IsVisible="False" BackgroundColor="#CC000000">
            <Border StrokeThickness="1" Stroke="#1E1E1E" BackgroundColor="#111111" 
                    WidthRequest="350" HorizontalOptions="Center" VerticalOptions="Center"
                    Padding="28,26">
                <Border.StrokeShape><RoundRectangle CornerRadius="26"/></Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="Black" Offset="0,12" Radius="36" Opacity="0.6"/>
                </Border.Shadow>
                <VerticalStackLayout Spacing="8">
                    <Label Text="🍽️ DETALLE DE TU ORDEN" FontAttributes="Bold" FontSize="15" TextColor="#fc4b08" HorizontalOptions="Center" CharacterSpacing="1"/>
                    
                    <BoxView HeightRequest="1" Color="#1E1E1E" Margin="0,10"/>
                    
                    <Grid ColumnDefinitions="Auto, *" RowSpacing="8" ColumnSpacing="12">
                        <Label Grid.Row="0" Grid.Column="0" Text="Folio:" TextColor="#777777" FontSize="13"/>
                        <Label Grid.Row="0" Grid.Column="1" x:Name="lblTicketFolio" TextColor="#DDDDDD" FontSize="13" FontAttributes="Bold" HorizontalOptions="End"/>
                        
                        <Label Grid.Row="1" Grid.Column="0" Text="Estado:" TextColor="#777777" FontSize="13"/>
                        <Label Grid.Row="1" Grid.Column="1" x:Name="lblTicketEstado" TextColor="#fc4b08" FontSize="13" FontAttributes="Bold" HorizontalOptions="End"/>
                    </Grid>

                    <BoxView HeightRequest="1" Color="#1E1E1E" Margin="0,10"/>

                    <CollectionView x:Name="listaDetallesTicket" MaximumHeightRequest="180">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="Auto, *, Auto" Padding="0,6">
                                    <Label Grid.Column="0" Text="{Binding Cantidad, StringFormat='{0}x '}" TextColor="#888888" FontSize="13" FontAttributes="Bold"/>
                                    <Label Grid.Column="1" Text="{Binding NombrePlatillo}" TextColor="#DDDDDD" FontSize="13" LineBreakMode="TailTruncation" Margin="6,0"/>
                                    <Label Grid.Column="2" Text="{Binding Subtotal, StringFormat='${0:F2}'}" TextColor="#F0F0F0" FontSize="13" FontAttributes="Bold"/>
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <BoxView HeightRequest="2" Color="#fc4b08" Margin="0,10">
                        <BoxView.Shadow>
                            <Shadow Brush="#fc4b08" Offset="0,0" Radius="6" Opacity="0.4"/>
                        </BoxView.Shadow>
                    </BoxView>
                    <Grid ColumnDefinitions="*, Auto">
                        <Label Grid.Column="0" Text="TOTAL:" FontAttributes="Bold" TextColor="#F0F0F0" FontSize="19"/>
                        <Label x:Name="lblTicketTotal" Grid.Column="1" Text="$0.00" FontAttributes="Bold" TextColor="#4CAF50" FontSize="22"/>
                    </Grid>
                    
                    <Button Text="Cerrar" BackgroundColor="#141414" TextColor="#E0E0E0" FontAttributes="Bold"
                            CornerRadius="16" HeightRequest="50" Margin="0,16,0,0" BorderWidth="1" BorderColor="#252525" 
                            Clicked="OnCerrarTicketClicked"/>
                </VerticalStackLayout>
            </Border>
        </Grid>
    </Grid>
</ContentPage>
<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AppCenaduria.Views.HistorialCliente"
             Title="Mis Pedidos"
             BackgroundColor="#0A0A0A">

    <Grid>
        <VerticalStackLayout Padding="0" Spacing="0">

            <!-- ══ Header ══ -->
            <Border StrokeThickness="0" BackgroundColor="#111111" Padding="24,28,24,20">
                <Border.StrokeShape><RoundRectangle CornerRadius="0,0,28,28"/></Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="Black" Offset="0,8" Radius="20" Opacity="0.4"/>
                </Border.Shadow>
                <VerticalStackLayout Spacing="6">
                    <HorizontalStackLayout HorizontalOptions="Center" Spacing="10">
                        <Border StrokeThickness="0" BackgroundColor="#1C1206" WidthRequest="38" HeightRequest="38">
                            <Border.StrokeShape><RoundRectangle CornerRadius="10"/></Border.StrokeShape>
                            <Label Text="🌮" FontSize="16" HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <Label Text="Mis Pedidos" FontSize="26" FontAttributes="Bold" TextColor="#F5F5F5" VerticalOptions="Center"/>
                    </HorizontalStackLayout>
                    <Label Text="Toca una orden para ver el detalle" TextColor="#555555" FontSize="13" HorizontalOptions="Center"/>
                    <BoxView HeightRequest="3" Color="#fc4b08" WidthRequest="40" HorizontalOptions="Center" Margin="0,6,0,0">
                        <BoxView.Shadow>
                            <Shadow Brush="#fc4b08" Offset="0,0" Radius="8" Opacity="0.5"/>
                        </BoxView.Shadow>
                    </BoxView>
                </VerticalStackLayout>
            </Border>

            <!-- ══ Lista ══ -->
            <CollectionView x:Name="listaMisPedidos" Margin="16,14,16,16">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border StrokeThickness="1" Stroke="#1A1A1A" BackgroundColor="#111111" 
                                Margin="0,0,0,10" Padding="0">
                            <Border.StrokeShape><RoundRectangle CornerRadius="18"/></Border.StrokeShape>
                            <Border.Shadow>
                                <Shadow Brush="Black" Offset="0,4" Radius="12" Opacity="0.3"/>
                            </Border.Shadow>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnPedidoTapped" CommandParameter="{Binding .}"/>
                            </Border.GestureRecognizers>

                            <Grid ColumnDefinitions="5, *, Auto">
                                <!-- Barra de estado -->
                                <BoxView Grid.Column="0">
                                    <BoxView.Triggers>
                                        <DataTrigger TargetType="BoxView" Binding="{Binding Estado}" Value="En preparación">
                                            <Setter Property="Color" Value="#FF9800"/>
                                        </DataTrigger>
                                        <DataTrigger TargetType="BoxView" Binding="{Binding Estado}" Value="En proceso de entrega">
                                            <Setter Property="Color" Value="#2196F3"/>
                                        </DataTrigger>
                                        <DataTrigger TargetType="BoxView" Binding="{Binding Estado}" Value="Entregado">
                                            <Setter Property="Color" Value="#4CAF50"/>
                                        </DataTrigger>
                                        <DataTrigger TargetType="BoxView" Binding="{Binding Estado}" Value="Cancelado">
                                            <Setter Property="Color" Value="#F44336"/>
                                        </DataTrigger>
                                    </BoxView.Triggers>
                                </BoxView>

                                <!-- Info -->
                                <VerticalStackLayout Grid.Column="1" Padding="16,14" Spacing="5">
                                    <Label Text="{Binding Folio, StringFormat='Orden #{0}'}" TextColor="#F0F0F0" FontAttributes="Bold" FontSize="16"/>
                                    <Label Text="{Binding FechaPedido, StringFormat='{0:dd/MM/yyyy hh:mm tt}'}" TextColor="#555555" FontSize="11"/>
                                    <Border StrokeThickness="0" BackgroundColor="#1C1206" Padding="8,3" HorizontalOptions="Start" Margin="0,2,0,0">
                                        <Border.StrokeShape><RoundRectangle CornerRadius="6"/></Border.StrokeShape>
                                        <Label Text="{Binding Estado}" TextColor="#fc4b08" FontAttributes="Bold" FontSize="10"/>
                                    </Border>
                                </VerticalStackLayout>

                                <!-- Total -->
                                <Label Grid.Column="2" Text="{Binding Total, StringFormat='${0:F2}'}" 
                                       TextColor="#F0F0F0" FontAttributes="Bold" FontSize="18" 
                                       VerticalOptions="Center" Margin="0,0,16,0"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>

                <CollectionView.EmptyView>
                    <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="10" Margin="0,50,0,0">
                        <Border StrokeThickness="1" Stroke="#1E1E1E" BackgroundColor="#111111" WidthRequest="70" HeightRequest="70" HorizontalOptions="Center">
                            <Border.StrokeShape><RoundRectangle CornerRadius="20"/></Border.StrokeShape>
                            <Label Text="🛒" FontSize="28" HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <Label Text="Aún no tienes pedidos" TextColor="#555555" FontSize="15" FontAttributes="Bold" HorizontalOptions="Center"/>
                        <Label Text="Tus compras aparecerán aquí" TextColor="#333333" FontSize="12" HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </CollectionView.EmptyView>
            </CollectionView>
        </VerticalStackLayout>

        <!-- ══ Modal Ticket ══ -->
        <Grid x:Name="modalTicketCliente" IsVisible="False" BackgroundColor="#CC000000">
            <Border StrokeThickness="1" Stroke="#1E1E1E" BackgroundColor="#111111" 
                    WidthRequest="340" HorizontalOptions="Center" VerticalOptions="Center"
                    Padding="26">
                <Border.StrokeShape><RoundRectangle CornerRadius="24"/></Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="#fc4b08" Offset="0,0" Radius="30" Opacity="0.15"/>
                </Border.Shadow>
                <VerticalStackLayout Spacing="10">
                    <Label Text="DETALLE DE TU ORDEN" FontAttributes="Bold" FontSize="14" TextColor="#888888" HorizontalOptions="Center" CharacterSpacing="1.5"/>
                    <Label x:Name="lblTicketFolio" Text="Folio:" TextColor="#F0F0F0" FontAttributes="Bold" FontSize="18" HorizontalOptions="Center"/>
                    <Label x:Name="lblTicketEstado" Text="Estado:" TextColor="#fc4b08" FontAttributes="Bold" FontSize="13" HorizontalOptions="Center"/>

                    <BoxView HeightRequest="1" Color="#1E1E1E" Margin="0,6"/>

                    <CollectionView x:Name="listaDetallesTicket" MaximumHeightRequest="150">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="Auto, *, Auto" Padding="0,5">
                                    <Label Grid.Column="0" Text="{Binding Cantidad, StringFormat='{0}x '}" TextColor="#666666" FontSize="13"/>
                                    <Label Grid.Column="1" Text="{Binding NombrePlatillo}" TextColor="#E0E0E0" FontSize="13" LineBreakMode="TailTruncation" Margin="5,0"/>
                                    <Label Grid.Column="2" Text="{Binding Subtotal, StringFormat='${0:F2}'}" TextColor="#E0E0E0" FontSize="13" FontAttributes="Bold"/>
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <BoxView HeightRequest="2" Color="#fc4b08" Margin="0,6">
                        <BoxView.Shadow>
                            <Shadow Brush="#fc4b08" Offset="0,0" Radius="6" Opacity="0.4"/>
                        </BoxView.Shadow>
                    </BoxView>
                    <Grid ColumnDefinitions="*, Auto">
                        <Label Grid.Column="0" Text="TOTAL" FontAttributes="Bold" TextColor="#888888" FontSize="14" CharacterSpacing="1"/>
                        <Label x:Name="lblTicketTotal" Grid.Column="1" Text="$0.00" FontAttributes="Bold" TextColor="#fc4b08" FontSize="20"/>
                    </Grid>
                    <Button Text="Cerrar" BackgroundColor="#fc4b08" TextColor="White" FontAttributes="Bold"
                            CornerRadius="14" HeightRequest="48" Margin="0,8,0,0" FontSize="15"
                            Clicked="OnCerrarTicketClicked">
                        <Button.Shadow>
                            <Shadow Brush="#fc4b08" Offset="0,4" Radius="14" Opacity="0.35"/>
                        </Button.Shadow>
                    </Button>
                </VerticalStackLayout>
            </Border>
        </Grid>
    </Grid>
</ContentPage>
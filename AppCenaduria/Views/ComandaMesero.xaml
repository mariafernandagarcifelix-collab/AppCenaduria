<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AppCenaduria.Views.ComandaMesero"
             Title="Comanda de la Mesa"
             BackgroundColor="#0A0A0A">

    <Grid RowDefinitions="Auto, *, Auto">

        <Border Grid.Row="0" StrokeThickness="0" BackgroundColor="#111111" Padding="24,30,24,22">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="0,0,28,28"/>
            </Border.StrokeShape>
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,8" Radius="22" Opacity="0.45"/>
            </Border.Shadow>
            <VerticalStackLayout Spacing="8">
                <HorizontalStackLayout HorizontalOptions="Center" Spacing="10">
                    <Border StrokeThickness="0" BackgroundColor="#1C1206" WidthRequest="40" HeightRequest="40">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12"/>
                        </Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="#fc4b08" Offset="0,0" Radius="10" Opacity="0.2"/>
                        </Border.Shadow>
                        <Label Text="📝" FontSize="17" HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>
                    <Label Text="Comanda" FontSize="28" FontAttributes="Bold" TextColor="#F5F5F5" VerticalOptions="Center" CharacterSpacing="0.5"/>
                </HorizontalStackLayout>
                <Label Text="Revisa los platillos antes de mandar a cocina" TextColor="#555555" FontSize="13" HorizontalOptions="Center"/>
                <BoxView HeightRequest="3" Color="#fc4b08" WidthRequest="44" HorizontalOptions="Center" Margin="0,4,0,0">
                    <BoxView.Shadow>
                        <Shadow Brush="#fc4b08" Offset="0,0" Radius="8" Opacity="0.5"/>
                    </BoxView.Shadow>
                </BoxView>
            </VerticalStackLayout>
        </Border>

        <CollectionView x:Name="listaComanda" Grid.Row="1" Margin="16,14,16,10">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border StrokeThickness="1" Stroke="#1A1A1A" BackgroundColor="#111111" Margin="0,0,0,10" Padding="14">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="20"/>
                        </Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="Black" Offset="0,4" Radius="14" Opacity="0.35"/>
                        </Border.Shadow>
                        <Grid RowDefinitions="Auto, Auto" ColumnDefinitions="78, *, Auto" ColumnSpacing="14" RowSpacing="10">

                            <Border Grid.Row="0" Grid.Column="0" StrokeThickness="1" Stroke="#1E1E1E" BackgroundColor="#0D0D0D" WidthRequest="70" HeightRequest="70">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="16"/>
                                </Border.StrokeShape>
                                <Image Source="{Binding FotografiaUrl}" Aspect="AspectFill" HeightRequest="70" WidthRequest="70">
                                    <Image.Clip>
                                        <RoundRectangleGeometry CornerRadius="16" Rect="0,0,70,70"/>
                                    </Image.Clip>
                                </Image>
                            </Border>

                            <VerticalStackLayout Grid.Row="0" Grid.Column="1" VerticalOptions="Center" Spacing="6">
                                <Label Text="{Binding Nombre}" FontSize="15" FontAttributes="Bold" TextColor="#F0F0F0" CharacterSpacing="0.3"/>
                                <HorizontalStackLayout Spacing="8" VerticalOptions="Center">
                                    <Button Text="−" CommandParameter="{Binding .}" Clicked="OnDisminuirCantidad" WidthRequest="32" HeightRequest="32" CornerRadius="16" BackgroundColor="#222222" TextColor="White" Padding="0" FontSize="16" FontAttributes="Bold"/>
                                    <Label Text="{Binding Cantidad}" FontSize="15" FontAttributes="Bold" TextColor="#fc4b08" VerticalOptions="Center" Margin="4,0"/>
                                    <Button Text="+" CommandParameter="{Binding .}" Clicked="OnAumentarCantidad" WidthRequest="32" HeightRequest="32" CornerRadius="16" BackgroundColor="#222222" TextColor="White" Padding="0" FontSize="16" FontAttributes="Bold"/>
                                </HorizontalStackLayout>
                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Row="0" Grid.Column="2" VerticalOptions="Center" Spacing="6">
                                <Label Text="{Binding Subtotal, StringFormat='${0:F2}'}" FontSize="18" FontAttributes="Bold" TextColor="#F0F0F0" HorizontalTextAlignment="End"/>
                                <Button Text="🗑️" CommandParameter="{Binding .}" Clicked="OnEliminarPlatillo" BackgroundColor="Transparent" HorizontalOptions="End" FontSize="18" HeightRequest="36" Padding="0"/>
                            </VerticalStackLayout>

                            <Border Grid.Row="1" Grid.ColumnSpan="3" StrokeThickness="1" Stroke="#252525" BackgroundColor="#161616" Padding="10,0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="12"/>
                                </Border.StrokeShape>
                                <Entry Text="{Binding Comentarios}" Placeholder="Añadir nota o instrucción (ej: sin cebolla)" TextColor="#DDDDDD" PlaceholderColor="#555555" FontSize="13" BackgroundColor="Transparent"/>
                            </Border>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>

            <CollectionView.EmptyView>
                <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="12" Margin="0,60,0,0">
                    <Border StrokeThickness="1" Stroke="#1E1E1E" BackgroundColor="#111111" WidthRequest="80" HeightRequest="80" HorizontalOptions="Center">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="24"/>
                        </Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="Black" Offset="0,4" Radius="12" Opacity="0.3"/>
                        </Border.Shadow>
                        <Label Text="📝" FontSize="32" HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>
                    <Label Text="La comanda está vacía" TextColor="#555555" FontSize="17" FontAttributes="Bold" HorizontalOptions="Center"/>
                    <Label Text="Explora el menú y agrega platillos" TextColor="#333333" FontSize="13" HorizontalOptions="Center"/>
                </VerticalStackLayout>
            </CollectionView.EmptyView>
        </CollectionView>

        <Border Grid.Row="2" StrokeThickness="1" Stroke="#1E1E1E" BackgroundColor="#111111" Margin="14,0,14,16" Padding="22,22">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="24"/>
            </Border.StrokeShape>
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,-6" Radius="22" Opacity="0.4"/>
            </Border.Shadow>
            <VerticalStackLayout Spacing="18">

                <Grid ColumnDefinitions="*, *" ColumnSpacing="14" Margin="0,0,0,4">
                    <VerticalStackLayout Grid.Column="0" Spacing="6">
                        <HorizontalStackLayout Spacing="6">
                            <Label Text="📦" FontSize="11"/>
                            <Label Text="Entrega" FontSize="12" TextColor="#777777" FontAttributes="Bold"/>
                        </HorizontalStackLayout>
                        <Border StrokeThickness="1" Stroke="#252525" BackgroundColor="#0D0D0D" Padding="10,0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="12"/>
                            </Border.StrokeShape>
                            <Picker x:Name="pickerEntrega" Title="Elegir..." TextColor="#E0E0E0" TitleColor="#444444" BackgroundColor="Transparent" SelectedIndexChanged="OnPickerEntregaSelectedIndexChanged">
                                <Picker.Items>
                                    <x:String>Domicilio</x:String>
                                    <x:String>Para recoger</x:String>
                                    <x:String>Comer ahí (Mesa)</x:String>
                                </Picker.Items>
                            </Picker>
                        </Border>
                    </VerticalStackLayout>
                    <VerticalStackLayout Grid.Column="1" Spacing="6">
                        <HorizontalStackLayout Spacing="6">
                            <Label Text="💳" FontSize="11"/>
                            <Label Text="Pago" FontSize="12" TextColor="#777777" FontAttributes="Bold"/>
                        </HorizontalStackLayout>
                        <Border StrokeThickness="1" Stroke="#252525" BackgroundColor="#0D0D0D" Padding="10,0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="12"/>
                            </Border.StrokeShape>
                            <Picker x:Name="pickerPago" Title="Elegir..." TextColor="#E0E0E0" TitleColor="#444444" BackgroundColor="Transparent">
                                <Picker.Items>
                                    <x:String>Efectivo</x:String>
                                    <x:String>Tarjeta</x:String>
                                </Picker.Items>
                            </Picker>
                        </Border>
                    </VerticalStackLayout>
                </Grid>

                <VerticalStackLayout x:Name="stackDatosMesero" Spacing="10" IsVisible="False" Margin="0,4,0,0">
                    <Label Text="DATOS DEL PEDIDO (MODO MESERO)" TextColor="#fc4b08" FontSize="10" FontAttributes="Bold" CharacterSpacing="1"/>

                    <Border x:Name="borderMeseroNombre" StrokeThickness="1" Stroke="#252525" BackgroundColor="#0D0D0D" Padding="12,0" IsVisible="False">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12"/>
                        </Border.StrokeShape>
                        <Entry x:Name="entryMeseroNombre" Placeholder="Nombre del Cliente" TextColor="White" PlaceholderColor="#555555" BackgroundColor="Transparent"/>
                    </Border>

                    <Border x:Name="borderMeseroTelefono" StrokeThickness="1" Stroke="#252525" BackgroundColor="#0D0D0D" Padding="12,0" IsVisible="False">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12"/>
                        </Border.StrokeShape>
                        <Entry x:Name="entryMeseroTelefono" Placeholder="Teléfono" Keyboard="Telephone" MaxLength="10" TextColor="White" PlaceholderColor="#555555" BackgroundColor="Transparent"/>
                    </Border>

                    <Border x:Name="borderMeseroDomicilio" StrokeThickness="1" Stroke="#252525" BackgroundColor="#0D0D0D" Padding="12,0" IsVisible="False">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12"/>
                        </Border.StrokeShape>
                        <Entry x:Name="entryMeseroDomicilio" Placeholder="Domicilio" TextColor="White" PlaceholderColor="#555555" BackgroundColor="Transparent"/>
                    </Border>

                    <Border x:Name="borderMeseroMesa" StrokeThickness="1" Stroke="#252525" BackgroundColor="#0D0D0D" Padding="12,0" IsVisible="False">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12"/>
                        </Border.StrokeShape>
                        <Entry x:Name="entryMeseroMesa" Placeholder="Indicador de Mesa (Ej: Mesa 5)" TextColor="White" PlaceholderColor="#555555" BackgroundColor="Transparent"/>
                    </Border>
                </VerticalStackLayout>

                <BoxView HeightRequest="1" Color="#1E1E1E"/>

                <Grid ColumnDefinitions="*, Auto">
                    <Label Grid.Column="0" Text="Total a Pagar" FontSize="16" TextColor="#777777" VerticalOptions="Center"/>
                    <Label Grid.Column="1" x:Name="lblTotal" Text="$0.00" FontSize="30" FontAttributes="Bold" TextColor="#fc4b08" VerticalOptions="Center"/>
                </Grid>

                <Button Text="Confirmar Pedido" 
                        Clicked="OnConfirmarPedidoClicked"
                        BackgroundColor="#fc4b08" 
                        TextColor="White" 
                        FontAttributes="Bold" 
                        FontSize="17"
                        CornerRadius="18" 
                        HeightRequest="56"
                        CharacterSpacing="0.3">
                    <Button.Shadow>
                        <Shadow Brush="#fc4b08" Offset="0,6" Radius="22" Opacity="0.45"/>
                    </Button.Shadow>
                </Button>
            </VerticalStackLayout>
        </Border>

    </Grid>
</ContentPage>
<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AppCenaduria.Views.MiCarrito"
             Title="Mi Carrito"
             BackgroundColor="#0A0A0A">

    <Grid RowDefinitions="Auto, *, Auto">

        <!-- ══ Header ══ -->
        <Border Grid.Row="0" StrokeThickness="0" BackgroundColor="#111111" Padding="24,30,24,22">
            <Border.StrokeShape><RoundRectangle CornerRadius="0,0,28,28"/></Border.StrokeShape>
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,8" Radius="22" Opacity="0.45"/>
            </Border.Shadow>
            <VerticalStackLayout Spacing="8">
                <HorizontalStackLayout HorizontalOptions="Center" Spacing="10">
                    <Border StrokeThickness="0" BackgroundColor="#1C1206" WidthRequest="40" HeightRequest="40">
                        <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="#fc4b08" Offset="0,0" Radius="10" Opacity="0.2"/>
                        </Border.Shadow>
                        <Label Text="🛒" FontSize="17" HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>
                    <Label Text="Tu Pedido" FontSize="28" FontAttributes="Bold" TextColor="#F5F5F5" VerticalOptions="Center" CharacterSpacing="0.5"/>
                </HorizontalStackLayout>
                <Label Text="Revisa tus platillos antes de confirmar" TextColor="#555555" FontSize="13" HorizontalOptions="Center"/>
                <BoxView HeightRequest="3" Color="#fc4b08" WidthRequest="44" HorizontalOptions="Center" Margin="0,4,0,0">
                    <BoxView.Shadow>
                        <Shadow Brush="#fc4b08" Offset="0,0" Radius="8" Opacity="0.5"/>
                    </BoxView.Shadow>
                </BoxView>
            </VerticalStackLayout>
        </Border>

        <!-- ══ Cart List ══ -->
        <CollectionView x:Name="listaCarrito" Grid.Row="1" Margin="16,14,16,10">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border StrokeThickness="1" Stroke="#1A1A1A" BackgroundColor="#111111" 
                            Margin="0,0,0,10" Padding="14">
                        <Border.StrokeShape><RoundRectangle CornerRadius="20"/></Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="Black" Offset="0,4" Radius="14" Opacity="0.35"/>
                        </Border.Shadow>
                        <Grid ColumnDefinitions="78, *, Auto" ColumnSpacing="14">

                            <!-- Image -->
                            <Border Grid.Column="0" StrokeThickness="1" Stroke="#1E1E1E" 
                                    BackgroundColor="#0D0D0D" WidthRequest="70" HeightRequest="70">
                                <Border.StrokeShape><RoundRectangle CornerRadius="16"/></Border.StrokeShape>
                                <Image Source="{Binding FotografiaUrl}" Aspect="AspectFill" 
                                       HeightRequest="70" WidthRequest="70">
                                    <Image.Clip>
                                        <RoundRectangleGeometry CornerRadius="16" Rect="0,0,70,70"/>
                                    </Image.Clip>
                                </Image>
                            </Border>

                            <!-- Info -->
                            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="6">
                                <Label Text="{Binding Nombre}" FontSize="15" FontAttributes="Bold" TextColor="#F0F0F0" CharacterSpacing="0.3"/>
                                <HorizontalStackLayout Spacing="6">
                                    <Border StrokeThickness="0" BackgroundColor="#1C1206" Padding="10,4">
                                        <Border.StrokeShape><RoundRectangle CornerRadius="8"/></Border.StrokeShape>
                                        <Label Text="{Binding Cantidad, StringFormat='×{0}'}" FontSize="12" 
                                               FontAttributes="Bold" TextColor="#fc4b08"/>
                                    </Border>
                                </HorizontalStackLayout>
                            </VerticalStackLayout>

                            <!-- Price -->
                            <VerticalStackLayout Grid.Column="2" VerticalOptions="Center" Spacing="2">
                                <Label Text="{Binding Subtotal, StringFormat='${0:F2}'}" 
                                       FontSize="18" FontAttributes="Bold" TextColor="#F0F0F0" 
                                       HorizontalTextAlignment="End"/>
                            </VerticalStackLayout>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>

            <CollectionView.EmptyView>
                <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="12" Margin="0,60,0,0">
                    <Border StrokeThickness="1" Stroke="#1E1E1E" BackgroundColor="#111111" 
                            WidthRequest="80" HeightRequest="80" HorizontalOptions="Center">
                        <Border.StrokeShape><RoundRectangle CornerRadius="24"/></Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="Black" Offset="0,4" Radius="12" Opacity="0.3"/>
                        </Border.Shadow>
                        <Label Text="🛒" FontSize="32" HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>
                    <Label Text="Tu carrito está vacío" TextColor="#555555" FontSize="17" FontAttributes="Bold" HorizontalOptions="Center"/>
                    <Label Text="Explora el menú y agrega platillos" TextColor="#333333" FontSize="13" HorizontalOptions="Center"/>
                </VerticalStackLayout>
            </CollectionView.EmptyView>
        </CollectionView>

        <!-- ══ Footer: Total & Confirm ══ -->
        <Border Grid.Row="2" StrokeThickness="1" Stroke="#1E1E1E" BackgroundColor="#111111" 
                Margin="14,0,14,16" Padding="22,22">
            <Border.StrokeShape><RoundRectangle CornerRadius="24"/></Border.StrokeShape>
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,-6" Radius="22" Opacity="0.4"/>
            </Border.Shadow>
            <VerticalStackLayout Spacing="18">
                
                <!-- Delivery & Payment Selectors -->
                <Grid ColumnDefinitions="*, *" ColumnSpacing="14" Margin="0,0,0,4">
                    <VerticalStackLayout Grid.Column="0" Spacing="6">
                        <HorizontalStackLayout Spacing="6">
                            <Label Text="📦" FontSize="11"/>
                            <Label Text="Entrega" FontSize="12" TextColor="#777777" FontAttributes="Bold"/>
                        </HorizontalStackLayout>
                        <Border StrokeThickness="1" Stroke="#252525" BackgroundColor="#0D0D0D" Padding="10,0">
                            <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                            <Picker x:Name="pickerEntrega" Title="Elegir..." TextColor="#E0E0E0" TitleColor="#444444" BackgroundColor="Transparent">
                                <Picker.Items>
                                    <x:String>Domicilio</x:String>
                                    <x:String>Recoger</x:String>
                                    <x:String>Comer ahí</x:String>
                                </Picker.Items>
                            </Picker>
                        </Border>
                    </VerticalStackLayout>
                    <VerticalStackLayout Grid.Column="1" Spacing="6">
                        <HorizontalStackLayout Spacing="6">
                            <Label Text="💳" FontSize="11"/>
                            <Label Text="Pago" FontSize="12" TextColor="#777777" FontAttributes="Bold"/>
                        </HorizontalStackLayout>
                        <Border StrokeThickness="1" Stroke="#252525" BackgroundColor="#0D0D0D" Padding="10,0">
                            <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                            <Picker x:Name="pickerPago" Title="Elegir..." TextColor="#E0E0E0" TitleColor="#444444" BackgroundColor="Transparent">
                                <Picker.Items>
                                    <x:String>Efectivo</x:String>
                                    <x:String>Tarjeta</x:String>
                                </Picker.Items>
                            </Picker>
                        </Border>
                    </VerticalStackLayout>
                </Grid>

                <!-- Divider -->
                <BoxView HeightRequest="1" Color="#1E1E1E"/>

                <!-- Total -->
                <Grid ColumnDefinitions="*, Auto">
                    <Label Grid.Column="0" Text="Total a Pagar" FontSize="16" TextColor="#777777" VerticalOptions="Center"/>
                    <Label Grid.Column="1" x:Name="lblTotal" Text="$0.00" FontSize="30" FontAttributes="Bold" TextColor="#fc4b08" VerticalOptions="Center"/>
                </Grid>

                <!-- CTA -->
                <Button Text="Confirmar Pedido" 
                        Clicked="OnConfirmarPedidoClicked"
                        BackgroundColor="#fc4b08" 
                        TextColor="White" 
                        FontAttributes="Bold" 
                        FontSize="17"
                        CornerRadius="18" 
                        HeightRequest="56"
                        CharacterSpacing="0.3">
                    <Button.Shadow>
                        <Shadow Brush="#fc4b08" Offset="0,6" Radius="22" Opacity="0.45"/>
                    </Button.Shadow>
                </Button>
            </VerticalStackLayout>
        </Border>

    </Grid>
</ContentPage>
<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AppCenaduria.Views.MiCarrito"
             Title="Mi Carrito"
             BackgroundColor="#0A0A0A">

    <Grid RowDefinitions="Auto, *, Auto">

        <!-- ══ Header ══ -->
        <Border Grid.Row="0" StrokeThickness="0" BackgroundColor="#111111" Padding="24,28,24,20">
            <Border.StrokeShape><RoundRectangle CornerRadius="0,0,28,28"/></Border.StrokeShape>
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,8" Radius="20" Opacity="0.4"/>
            </Border.Shadow>
            <VerticalStackLayout Spacing="6">
                <HorizontalStackLayout HorizontalOptions="Center" Spacing="10">
                    <Border StrokeThickness="0" BackgroundColor="#1C1206" WidthRequest="38" HeightRequest="38">
                        <Border.StrokeShape><RoundRectangle CornerRadius="10"/></Border.StrokeShape>
                        <Label Text="🛒" FontSize="16" HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>
                    <Label Text="Tu Pedido" FontSize="26" FontAttributes="Bold" TextColor="#F5F5F5" VerticalOptions="Center"/>
                </HorizontalStackLayout>
                <Label Text="Revisa tus platillos antes de confirmar" TextColor="#555555" FontSize="13" HorizontalOptions="Center"/>
                <BoxView HeightRequest="3" Color="#fc4b08" WidthRequest="40" HorizontalOptions="Center" Margin="0,6,0,0">
                    <BoxView.Shadow>
                        <Shadow Brush="#fc4b08" Offset="0,0" Radius="8" Opacity="0.5"/>
                    </BoxView.Shadow>
                </BoxView>
            </VerticalStackLayout>
        </Border>

        <!-- ══ Lista del Carrito ══ -->
        <CollectionView x:Name="listaCarrito" Grid.Row="1" Margin="16,14,16,10">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border StrokeThickness="1" Stroke="#1A1A1A" BackgroundColor="#111111" 
                            Margin="0,0,0,10" Padding="14">
                        <Border.StrokeShape><RoundRectangle CornerRadius="18"/></Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="Black" Offset="0,4" Radius="12" Opacity="0.3"/>
                        </Border.Shadow>
                        <Grid ColumnDefinitions="76, *, Auto" ColumnSpacing="14">

                            <!-- Imagen -->
                            <Border Grid.Column="0" StrokeThickness="1" Stroke="#1E1E1E" 
                                    BackgroundColor="#0D0D0D" WidthRequest="68" HeightRequest="68">
                                <Border.StrokeShape><RoundRectangle CornerRadius="14"/></Border.StrokeShape>
                                <Image Source="{Binding FotografiaUrl}" Aspect="AspectFill" 
                                       HeightRequest="68" WidthRequest="68">
                                    <Image.Clip>
                                        <RoundRectangleGeometry CornerRadius="14" Rect="0,0,68,68"/>
                                    </Image.Clip>
                                </Image>
                            </Border>

                            <!-- Info -->
                            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="4">
                                <Label Text="{Binding Nombre}" FontSize="15" FontAttributes="Bold" TextColor="#F0F0F0"/>
                                <HorizontalStackLayout Spacing="4">
                                    <Border StrokeThickness="0" BackgroundColor="#1C1206" Padding="8,3">
                                        <Border.StrokeShape><RoundRectangle CornerRadius="6"/></Border.StrokeShape>
                                        <Label Text="{Binding Cantidad, StringFormat='×{0}'}" FontSize="11" 
                                               FontAttributes="Bold" TextColor="#fc4b08"/>
                                    </Border>
                                </HorizontalStackLayout>
                            </VerticalStackLayout>

                            <!-- Precio -->
                            <Label Grid.Column="2" Text="{Binding Subtotal, StringFormat='${0:F2}'}" 
                                   FontSize="17" FontAttributes="Bold" TextColor="#F0F0F0" VerticalOptions="Center"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>

            <CollectionView.EmptyView>
                <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="10" Margin="0,60,0,0">
                    <Border StrokeThickness="1" Stroke="#1E1E1E" BackgroundColor="#111111" 
                            WidthRequest="70" HeightRequest="70" HorizontalOptions="Center">
                        <Border.StrokeShape><RoundRectangle CornerRadius="20"/></Border.StrokeShape>
                        <Label Text="🛒" FontSize="28" HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>
                    <Label Text="Tu carrito está vacío" TextColor="#555555" FontSize="16" FontAttributes="Bold" HorizontalOptions="Center"/>
                    <Label Text="Explora el menú y agrega platillos" TextColor="#333333" FontSize="12" HorizontalOptions="Center"/>
                </VerticalStackLayout>
            </CollectionView.EmptyView>
        </CollectionView>

        <!-- ══ Footer: Total y Confirmar ══ -->
        <Border Grid.Row="2" StrokeThickness="1" Stroke="#1E1E1E" BackgroundColor="#111111" 
                Margin="14,0,14,16" Padding="22,20">
            <Border.StrokeShape><RoundRectangle CornerRadius="22"/></Border.StrokeShape>
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,-6" Radius="20" Opacity="0.35"/>
            </Border.Shadow>
            <VerticalStackLayout Spacing="16">
                
                <Grid ColumnDefinitions="*, *" ColumnSpacing="15" Margin="0,0,0,5">
                    <VerticalStackLayout Grid.Column="0" Spacing="5">
                        <Label Text="Entrega" FontSize="12" TextColor="#777777"/>
                        <Border StrokeThickness="1" Stroke="#2A2A2A" BackgroundColor="#1A1A1A" Padding="10,0">
                            <Border.StrokeShape><RoundRectangle CornerRadius="8"/></Border.StrokeShape>
                            <Picker x:Name="pickerEntrega" Title="Elegir..." TextColor="#E0E0E0" TitleColor="#555555" BackgroundColor="Transparent">
                                <Picker.Items>
                                    <x:String>Domicilio</x:String>
                                    <x:String>Recoger</x:String>
                                    <x:String>Comer ahí</x:String>
                                </Picker.Items>
                            </Picker>
                        </Border>
                    </VerticalStackLayout>
                    <VerticalStackLayout Grid.Column="1" Spacing="5">
                        <Label Text="Pago" FontSize="12" TextColor="#777777"/>
                        <Border StrokeThickness="1" Stroke="#2A2A2A" BackgroundColor="#1A1A1A" Padding="10,0">
                            <Border.StrokeShape><RoundRectangle CornerRadius="8"/></Border.StrokeShape>
                            <Picker x:Name="pickerPago" Title="Elegir..." TextColor="#E0E0E0" TitleColor="#555555" BackgroundColor="Transparent">
                                <Picker.Items>
                                    <x:String>Efectivo</x:String>
                                    <x:String>Tarjeta</x:String>
                                </Picker.Items>
                            </Picker>
                        </Border>
                    </VerticalStackLayout>
                </Grid>

                <Grid ColumnDefinitions="*, Auto">
                    <Label Grid.Column="0" Text="Total a Pagar" FontSize="16" TextColor="#777777" VerticalOptions="Center"/>
                    <Label Grid.Column="1" x:Name="lblTotal" Text="$0.00" FontSize="28" FontAttributes="Bold" TextColor="#fc4b08" VerticalOptions="Center"/>
                </Grid>

                <Button Text="Confirmar Pedido" 
                        Clicked="OnConfirmarPedidoClicked"
                        BackgroundColor="#fc4b08" 
                        TextColor="White" 
                        FontAttributes="Bold" 
                        FontSize="16"
                        CornerRadius="16" 
                        HeightRequest="54">
                    <Button.Shadow>
                        <Shadow Brush="#fc4b08" Offset="0,6" Radius="20" Opacity="0.4"/>
                    </Button.Shadow>
                </Button>
            </VerticalStackLayout>
        </Border>

    </Grid>
</ContentPage>
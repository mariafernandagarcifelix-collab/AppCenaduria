<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AppCenaduria.Views.Reportes"
             Title="Dashboard de Ventas"
             BackgroundColor="#121212">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">

            <Label Text="Métricas del Negocio 📊" FontSize="26" FontAttributes="Bold" TextColor="#fc4b08" HorizontalOptions="Center"/>

            <Grid ColumnDefinitions="*, *" ColumnSpacing="15">
                <Frame Grid.Column="0" BackgroundColor="#1A1A1A" BorderColor="#fc4b08" CornerRadius="15" Padding="15">
                    <VerticalStackLayout Spacing="5" HorizontalOptions="Center">
                        <Label Text="Hoy" TextColor="#E0E0E0" FontSize="14" HorizontalOptions="Center"/>
                        <Label x:Name="lblVentasHoy" Text="$0.00" FontSize="22" FontAttributes="Bold" TextColor="#4CAF50" HorizontalOptions="Center"/>
                        <Label x:Name="lblPedidosHoy" Text="0 pedidos" TextColor="#757575" FontSize="12" HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </Frame>

                <Frame Grid.Column="1" BackgroundColor="#1A1A1A" BorderColor="#333333" CornerRadius="15" Padding="15">
                    <VerticalStackLayout Spacing="5" HorizontalOptions="Center">
                        <Label Text="Este Mes" TextColor="#E0E0E0" FontSize="14" HorizontalOptions="Center"/>
                        <Label x:Name="lblVentasMes" Text="$0.00" FontSize="22" FontAttributes="Bold" TextColor="White" HorizontalOptions="Center"/>
                        <Label x:Name="lblPedidosMes" Text="0 pedidos" TextColor="#757575" FontSize="12" HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </Frame>
            </Grid>

            <BoxView HeightRequest="1" Color="#333333" Margin="0,5"/>

            <Label Text="Filtrar Historial de Ventas" FontSize="18" FontAttributes="Bold" TextColor="White"/>

            <Grid ColumnDefinitions="*, *, Auto" ColumnSpacing="10" VerticalOptions="Center">
                <VerticalStackLayout Grid.Column="0">
                    <Label Text="Desde:" TextColor="#757575" FontSize="12" Margin="0,0,0,2"/>
                    <DatePicker x:Name="dpInicio" BackgroundColor="#1A1A1A" TextColor="White" Format="dd/MM/yyyy"/>
                </VerticalStackLayout>

                <VerticalStackLayout Grid.Column="1">
                    <Label Text="Hasta:" TextColor="#757575" FontSize="12" Margin="0,0,0,2"/>
                    <DatePicker x:Name="dpFin" BackgroundColor="#1A1A1A" TextColor="White" Format="dd/MM/yyyy"/>
                </VerticalStackLayout>

                <Button Grid.Column="2" Text="🔍 Buscar" BackgroundColor="#fc4b08" TextColor="White" 
                        VerticalOptions="End" FontAttributes="Bold" Clicked="OnFiltrarClicked"/>
            </Grid>

            <Frame BackgroundColor="#1A1A1A" BorderColor="#4CAF50" CornerRadius="10" Padding="10">
                <HorizontalStackLayout HorizontalOptions="Center" Spacing="10">
                    <Label Text="Total del periodo:" TextColor="White" FontSize="16" VerticalOptions="Center"/>
                    <Label x:Name="lblTotalFiltrado" Text="$0.00" TextColor="#4CAF50" FontAttributes="Bold" FontSize="18" VerticalOptions="Center"/>
                </HorizontalStackLayout>
            </Frame>

            <Label Text="Resultados:" TextColor="#E0E0E0" FontSize="14"/>

            <CollectionView x:Name="listaResumen" HeightRequest="300">
                <CollectionView.EmptyView>
                    <Label Text="No hay ventas en estas fechas." TextColor="#757575" HorizontalOptions="Center" Margin="0,20"/>
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Grid ColumnDefinitions="*, Auto" Padding="0,10">
                            <VerticalStackLayout Grid.Column="0">
                                <Label Text="{Binding Folio, StringFormat='Orden #{0}'}" TextColor="White" FontAttributes="Bold"/>
                                <Label Text="{Binding FechaPedido, StringFormat='{0:dd/MM/yyyy hh:mm tt}'}" TextColor="#757575" FontSize="12"/>
                            </VerticalStackLayout>
                            <Label Grid.Column="1" Text="{Binding Total, StringFormat='${0:F2}'}" TextColor="#4CAF50" FontAttributes="Bold" VerticalOptions="Center"/>
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
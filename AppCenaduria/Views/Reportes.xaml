<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AppCenaduria.Views.Reportes"
             Title="Dashboard de Ventas"
             BackgroundColor="#0A0A0A">

    <ScrollView>
        <VerticalStackLayout Padding="0" Spacing="0">

            <!-- ══ Header ══ -->
            <Border StrokeThickness="0" BackgroundColor="#111111" Padding="24,28,24,20">
                <Border.StrokeShape><RoundRectangle CornerRadius="0,0,28,28"/></Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="Black" Offset="0,8" Radius="20" Opacity="0.4"/>
                </Border.Shadow>
                <VerticalStackLayout Spacing="6">
                    <HorizontalStackLayout HorizontalOptions="Center" Spacing="10">
                        <Border StrokeThickness="0" BackgroundColor="#1C1206" WidthRequest="38" HeightRequest="38">
                            <Border.StrokeShape><RoundRectangle CornerRadius="10"/></Border.StrokeShape>
                            <Label Text="📊" FontSize="16" HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <Label Text="Dashboard" FontSize="26" FontAttributes="Bold" TextColor="#F5F5F5" VerticalOptions="Center" CharacterSpacing="0.5"/>
                    </HorizontalStackLayout>
                    <Label Text="Visualiza el desempeño y ventas del negocio" TextColor="#555555" FontSize="13" HorizontalOptions="Center"/>
                    <BoxView HeightRequest="3" Color="#fc4b08" WidthRequest="40" HorizontalOptions="Center" Margin="0,6,0,0">
                        <BoxView.Shadow>
                            <Shadow Brush="#fc4b08" Offset="0,0" Radius="8" Opacity="0.5"/>
                        </BoxView.Shadow>
                    </BoxView>
                </VerticalStackLayout>
            </Border>

            <VerticalStackLayout Padding="16,20,16,16" Spacing="18">
                <!-- ══ Métricas Principales ══ -->
                <Grid ColumnDefinitions="*, *" ColumnSpacing="12">

                    <!-- Ventas de Hoy -->
                    <Border Grid.Column="0" StrokeThickness="1" Stroke="#fc4b08" BackgroundColor="#111111" Padding="18">
                        <Border.StrokeShape><RoundRectangle CornerRadius="18"/></Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="#fc4b08" Offset="0,0" Radius="15" Opacity="0.15"/>
                        </Border.Shadow>
                        <VerticalStackLayout Spacing="6" HorizontalOptions="Center">
                            <Border StrokeThickness="0" BackgroundColor="#1C1206" WidthRequest="40" HeightRequest="40" HorizontalOptions="Center">
                                <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                                <Label Text="🔥" FontSize="18" HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                            <Label Text="Hoy" TextColor="#777777" FontSize="12" FontAttributes="Bold" HorizontalOptions="Center"/>
                            <Label x:Name="lblVentasHoy" Text="$0.00" FontSize="24" FontAttributes="Bold" TextColor="#4CAF50" HorizontalOptions="Center"/>
                            <Label x:Name="lblPedidosHoy" Text="0 pedidos" TextColor="#555555" FontSize="11" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Ventas del Mes -->
                    <Border Grid.Column="1" StrokeThickness="1" Stroke="#1E1E1E" BackgroundColor="#111111" Padding="18">
                        <Border.StrokeShape><RoundRectangle CornerRadius="18"/></Border.StrokeShape>
                        <VerticalStackLayout Spacing="6" HorizontalOptions="Center">
                            <Border StrokeThickness="0" BackgroundColor="#0F0F0F" WidthRequest="40" HeightRequest="40" HorizontalOptions="Center">
                                <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                                <Label Text="📅" FontSize="18" HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                            <Label Text="Este Mes" TextColor="#777777" FontSize="12" FontAttributes="Bold" HorizontalOptions="Center"/>
                            <Label x:Name="lblVentasMes" Text="$0.00" FontSize="24" FontAttributes="Bold" TextColor="#F0F0F0" HorizontalOptions="Center"/>
                            <Label x:Name="lblPedidosMes" Text="0 pedidos" TextColor="#555555" FontSize="11" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <BoxView HeightRequest="1" Color="#1E1E1E" Margin="0,4"/>

                <!-- ══ Filtro por Fechas ══ -->
                <Border StrokeThickness="1" Stroke="#1E1E1E" BackgroundColor="#111111" Padding="18">
                    <Border.StrokeShape><RoundRectangle CornerRadius="18"/></Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="0,4" Radius="12" Opacity="0.3"/>
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="14">
                        <HorizontalStackLayout Spacing="8">
                            <BoxView WidthRequest="4" HeightRequest="16" Color="#fc4b08" VerticalOptions="Center"/>
                            <Label Text="FILTRAR HISTORIAL" TextColor="#888888" FontSize="11" FontAttributes="Bold" CharacterSpacing="1" VerticalOptions="Center"/>
                        </HorizontalStackLayout>

                        <Grid ColumnDefinitions="*, *, Auto" ColumnSpacing="12" VerticalOptions="Center">
                            <Border Grid.Column="0" StrokeThickness="1" Stroke="#252525" BackgroundColor="#0F0F0F" Padding="12,8">
                                <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                                <VerticalStackLayout>
                                    <Label Text="Desde:" TextColor="#555555" FontSize="11"/>
                                    <DatePicker x:Name="dpInicio" BackgroundColor="Transparent" TextColor="White" Format="dd/MM/yyyy"/>
                                </VerticalStackLayout>
                            </Border>

                            <Border Grid.Column="1" StrokeThickness="1" Stroke="#252525" BackgroundColor="#0F0F0F" Padding="12,8">
                                <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                                <VerticalStackLayout>
                                    <Label Text="Hasta:" TextColor="#555555" FontSize="11"/>
                                    <DatePicker x:Name="dpFin" BackgroundColor="Transparent" TextColor="White" Format="dd/MM/yyyy"/>
                                </VerticalStackLayout>
                            </Border>

                            <Button Grid.Column="2" Text="🔍" BackgroundColor="#fc4b08" TextColor="White" 
                                    VerticalOptions="End" FontAttributes="Bold" Clicked="OnFiltrarClicked"
                                    WidthRequest="50" HeightRequest="50" CornerRadius="16" Padding="0" FontSize="20">
                                <Button.Shadow>
                                    <Shadow Brush="#fc4b08" Offset="0,4" Radius="10" Opacity="0.3"/>
                                </Button.Shadow>
                            </Button>
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <!-- ══ Total del Período ══ -->
                <Border StrokeThickness="1" Stroke="#1E3A1E" BackgroundColor="#0D1A0D" Padding="16">
                    <Border.StrokeShape><RoundRectangle CornerRadius="16"/></Border.StrokeShape>
                    <HorizontalStackLayout HorizontalOptions="Center" Spacing="14">
                        <Label Text="💰" FontSize="22" VerticalOptions="Center"/>
                        <Label Text="Total del periodo filtrado:" TextColor="#AAAAAA" FontSize="14" VerticalOptions="Center"/>
                        <Label x:Name="lblTotalFiltrado" Text="$0.00" TextColor="#4CAF50" FontAttributes="Bold" FontSize="22" VerticalOptions="Center"/>
                    </HorizontalStackLayout>
                </Border>

                <!-- ══ Resultados ══ -->
                <Grid ColumnDefinitions="*, Auto, *" Margin="0,10,0,0">
                    <BoxView Grid.Column="0" HeightRequest="1" Color="#1E1E1E" VerticalOptions="Center"/>
                    <Border Grid.Column="1" StrokeThickness="0" BackgroundColor="#161616" Padding="12,4" Margin="10,0">
                        <Border.StrokeShape><RoundRectangle CornerRadius="8"/></Border.StrokeShape>
                        <Label Text="RESULTADOS" TextColor="#666666" FontSize="10" FontAttributes="Bold" CharacterSpacing="2"/>
                    </Border>
                    <BoxView Grid.Column="2" HeightRequest="1" Color="#1E1E1E" VerticalOptions="Center"/>
                </Grid>

                <CollectionView x:Name="listaResumen" HeightRequest="300" Margin="0,10,0,0">
                    <CollectionView.EmptyView>
                        <VerticalStackLayout HorizontalOptions="Center" Spacing="10" Margin="0,40,0,0">
                            <Border StrokeThickness="1" Stroke="#1E1E1E" BackgroundColor="#111111" WidthRequest="70" HeightRequest="70" HorizontalOptions="Center">
                                <Border.StrokeShape><RoundRectangle CornerRadius="20"/></Border.StrokeShape>
                                <Label Text="📭" FontSize="28" HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                            <Label Text="No hay ventas registradas aquí." TextColor="#555555" FontSize="15" FontAttributes="Bold" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </CollectionView.EmptyView>
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border StrokeThickness="1" Stroke="#1E1E1E" BackgroundColor="#111111" Margin="0,0,0,10" Padding="16,14">
                                <Border.StrokeShape><RoundRectangle CornerRadius="14"/></Border.StrokeShape>
                                <Grid ColumnDefinitions="*, Auto">
                                    <VerticalStackLayout Grid.Column="0" Spacing="4">
                                        <Label Text="{Binding Folio, StringFormat='Orden #{0}'}" TextColor="#F0F0F0" FontAttributes="Bold" FontSize="15"/>
                                        <Label Text="{Binding FechaPedido, StringFormat='{0:dd/MM/yyyy hh:mm tt}'}" TextColor="#666666" FontSize="11"/>
                                    </VerticalStackLayout>
                                    <Label Grid.Column="1" Text="{Binding Total, StringFormat='${0:F2}'}" TextColor="#4CAF50" FontAttributes="Bold" FontSize="16" VerticalOptions="Center"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AppCenaduria.Views.Perfil"
             Title="Mi Cuenta"
             BackgroundColor="#0A0A0A">

    <ScrollView>
        <VerticalStackLayout Padding="0" Spacing="0">

            <!-- ══ Header ══ -->
            <Border StrokeThickness="0" BackgroundColor="#111111" Padding="28,32,28,28">
                <Border.StrokeShape><RoundRectangle CornerRadius="0,0,28,28"/></Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="Black" Offset="0,8" Radius="20" Opacity="0.4"/>
                </Border.Shadow>
                <VerticalStackLayout Spacing="10" HorizontalOptions="Center">
                    <!-- Avatar -->
                    <Border StrokeThickness="2" Stroke="#fc4b08" BackgroundColor="#0F0F0F"
                            HorizontalOptions="Center" WidthRequest="86" HeightRequest="86">
                        <Border.StrokeShape><RoundRectangle CornerRadius="43"/></Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="#fc4b08" Offset="0,0" Radius="22" Opacity="0.3"/>
                        </Border.Shadow>
                        <Label Text="👤" FontSize="34" HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>
                    <Label Text="Mi Perfil" FontSize="24" FontAttributes="Bold" TextColor="#F5F5F5" HorizontalOptions="Center"/>
                    <Label Text="Mantén tus datos actualizados" TextColor="#555555" FontSize="13" HorizontalOptions="Center"/>
                    <BoxView HeightRequest="3" Color="#fc4b08" WidthRequest="40" HorizontalOptions="Center" Margin="0,4,0,0">
                        <BoxView.Shadow>
                            <Shadow Brush="#fc4b08" Offset="0,0" Radius="8" Opacity="0.5"/>
                        </BoxView.Shadow>
                    </BoxView>
                </VerticalStackLayout>
            </Border>

            <VerticalStackLayout Padding="18,20" Spacing="14">

                <!-- ══ Formulario ══ -->
                <Border StrokeThickness="1" Stroke="#1E1E1E" BackgroundColor="#111111" Padding="22,20">
                    <Border.StrokeShape><RoundRectangle CornerRadius="20"/></Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="0,6" Radius="18" Opacity="0.35"/>
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="18">
                        <HorizontalStackLayout Spacing="8">
                            <BoxView WidthRequest="4" HeightRequest="16" Color="#fc4b08" VerticalOptions="Center">

                            </BoxView>
                            <Label Text="DATOS PERSONALES" TextColor="#888888" FontSize="11" 
                                   FontAttributes="Bold" CharacterSpacing="1" VerticalOptions="Center"/>
                        </HorizontalStackLayout>

                        <!-- Nombre -->
                        <VerticalStackLayout Spacing="8">
                            <Label Text="Nombre Completo" TextColor="#AAAAAA" FontSize="12" FontAttributes="Bold"/>
                            <Border StrokeThickness="1" Stroke="#252525" BackgroundColor="#0F0F0F" Padding="16,0" HeightRequest="50">
                                <Border.StrokeShape><RoundRectangle CornerRadius="14"/></Border.StrokeShape>
                                <Entry x:Name="txtNombre" TextColor="White" BackgroundColor="Transparent" 
                                       Placeholder="Tu nombre..." PlaceholderColor="#444444" FontSize="15"/>
                            </Border>
                        </VerticalStackLayout>

                        <!-- Teléfono -->
                        <VerticalStackLayout Spacing="8">
                            <Label Text="Teléfono de Contacto" TextColor="#AAAAAA" FontSize="12" FontAttributes="Bold"/>
                            <Border StrokeThickness="1" Stroke="#252525" BackgroundColor="#0F0F0F" Padding="16,0" HeightRequest="50">
                                <Border.StrokeShape><RoundRectangle CornerRadius="14"/></Border.StrokeShape>
                                <Entry x:Name="txtTelefono" TextColor="White" BackgroundColor="Transparent" 
                                       Keyboard="Telephone" Placeholder="Ej. 687..." PlaceholderColor="#444444" FontSize="15"/>
                            </Border>
                        </VerticalStackLayout>

                        <!-- Domicilio -->
                        <VerticalStackLayout Spacing="8">
                            <Label Text="Domicilio de Entrega" TextColor="#AAAAAA" FontSize="12" FontAttributes="Bold"/>
                            <Border StrokeThickness="1" Stroke="#252525" BackgroundColor="#0F0F0F" Padding="16,10">
                                <Border.StrokeShape><RoundRectangle CornerRadius="14"/></Border.StrokeShape>
                                <Editor x:Name="txtDomicilio" TextColor="White" BackgroundColor="Transparent" 
                                        HeightRequest="85" Placeholder="Calle, número, colonia..." PlaceholderColor="#444444" FontSize="14"/>
                            </Border>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Border>

                <!-- ══ Botón Guardar ══ -->
                <Button Text="Actualizar Datos" 
                        Clicked="OnGuardarPerfilClicked"
                        BackgroundColor="#fc4b08" 
                        TextColor="White" 
                        FontAttributes="Bold" 
                        FontSize="16"
                        CornerRadius="16" 
                        HeightRequest="56" 
                        Margin="0,4,0,30">
                    <Button.Shadow>
                        <Shadow Brush="#fc4b08" Offset="0,6" Radius="20" Opacity="0.4"/>
                    </Button.Shadow>
                </Button>

            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
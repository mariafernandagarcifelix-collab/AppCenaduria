<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AppCenaduria.Views.VerMenuCliente"
             Title="Menú de la Cenaduría"
             BackgroundColor="#0A0A0A">

    <Grid RowDefinitions="Auto, *">

        <!-- ══ Header ══ -->
        <Border Grid.Row="0" StrokeThickness="0" BackgroundColor="#111111" Padding="24,28,24,20">
            <Border.StrokeShape><RoundRectangle CornerRadius="0,0,28,28"/></Border.StrokeShape>
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,8" Radius="20" Opacity="0.4"/>
            </Border.Shadow>
            <VerticalStackLayout Spacing="6">
                <HorizontalStackLayout HorizontalOptions="Center" Spacing="10">
                    <Border StrokeThickness="0" BackgroundColor="#1C1206" WidthRequest="38" HeightRequest="38">
                        <Border.StrokeShape><RoundRectangle CornerRadius="10"/></Border.StrokeShape>
                        <Label Text="🍽️" FontSize="16" HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>
                    <Label Text="Nuestro Menú" FontSize="26" FontAttributes="Bold" TextColor="#F5F5F5" VerticalOptions="Center"/>
                </HorizontalStackLayout>
                <Label Text="¡Pide tus antojitos favoritos!" TextColor="#555555" FontSize="13" HorizontalOptions="Center"/>
                <BoxView HeightRequest="3" Color="#fc4b08" WidthRequest="40" HorizontalOptions="Center" Margin="0,6,0,0">
                    <BoxView.Shadow>
                        <Shadow Brush="#fc4b08" Offset="0,0" Radius="8" Opacity="0.5"/>
                    </BoxView.Shadow>
                </BoxView>
            </VerticalStackLayout>
        </Border>

        <!-- ══ Lista de Platillos ══ -->
        <CollectionView x:Name="listaPlatillos" Grid.Row="1" Margin="16,14,16,16">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border StrokeThickness="1" Stroke="#1A1A1A" BackgroundColor="#111111" 
                            Margin="0,0,0,12" Padding="0">
                        <Border.StrokeShape><RoundRectangle CornerRadius="18"/></Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="Black" Offset="0,4" Radius="12" Opacity="0.3"/>
                        </Border.Shadow>
                        <Grid ColumnDefinitions="110, *" RowDefinitions="Auto, Auto, Auto" Padding="14" ColumnSpacing="16">

                            <!-- Imagen del platillo -->
                            <Border Grid.RowSpan="3" Grid.Column="0" StrokeThickness="1" Stroke="#1E1E1E"
                                    BackgroundColor="#0D0D0D" WidthRequest="90" HeightRequest="90">
                                <Border.StrokeShape><RoundRectangle CornerRadius="16"/></Border.StrokeShape>
                                <Image Source="{Binding FotografiaUrl}" Aspect="AspectFill" 
                                       HeightRequest="90" WidthRequest="90">
                                    <Image.Clip>
                                        <RoundRectangleGeometry CornerRadius="16" Rect="0,0,90,90"/>
                                    </Image.Clip>
                                </Image>
                            </Border>

                            <!-- Nombre -->
                            <Label Grid.Row="0" Grid.Column="1" Text="{Binding Nombre}" 
                                   FontSize="17" FontAttributes="Bold" TextColor="#F0F0F0"/>

                            <!-- Descripción -->
                            <Label Grid.Row="1" Grid.Column="1" Text="{Binding Descripcion}" 
                                   FontSize="12" TextColor="#555555" MaxLines="2" 
                                   LineBreakMode="TailTruncation" Margin="0,4,0,0"/>

                            <!-- Precio y botón -->
                            <Grid Grid.Row="2" Grid.Column="1" ColumnDefinitions="*, Auto" Margin="0,8,0,0">
                                <Label Grid.Column="0" Text="{Binding Precio, StringFormat='${0:F2}'}" 
                                       FontSize="20" FontAttributes="Bold" TextColor="#fc4b08" VerticalOptions="Center"/>
                                <Button Grid.Column="1" Text="＋ Agregar" TextColor="White" BackgroundColor="#fc4b08" 
                                        FontAttributes="Bold" FontSize="12" CornerRadius="12" 
                                        HeightRequest="36" Padding="16,0"
                                        Clicked="OnAgregarClicked" CommandParameter="{Binding .}">
                                    <Button.Shadow>
                                        <Shadow Brush="#fc4b08" Offset="0,3" Radius="10" Opacity="0.35"/>
                                    </Button.Shadow>
                                </Button>
                            </Grid>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>

</ContentPage>
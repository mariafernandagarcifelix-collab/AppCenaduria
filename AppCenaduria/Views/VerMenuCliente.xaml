<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AppCenaduria.Views.VerMenuCliente"
             Title="Menú de la Cenaduría"
             BackgroundColor="#0A0A0A">

    <Grid RowDefinitions="Auto, Auto, Auto, *">

        <!-- ══ Header ══ -->
        <Border Grid.Row="0" StrokeThickness="0" BackgroundColor="#111111" Padding="20,24,20,18">
            <Border.StrokeShape><RoundRectangle CornerRadius="0,0,24,24"/></Border.StrokeShape>
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,6" Radius="16" Opacity="0.4"/>
            </Border.Shadow>
            <VerticalStackLayout Spacing="6">
                <HorizontalStackLayout Spacing="10">
                    <Border StrokeThickness="0" BackgroundColor="#1C1206" WidthRequest="38" HeightRequest="38">
                        <Border.StrokeShape><RoundRectangle CornerRadius="10"/></Border.StrokeShape>
                        <Label Text="🔥" FontSize="16" HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>
                    <VerticalStackLayout Spacing="2">
                        <Label Text="¿Qué se te antoja hoy?" FontSize="22" FontAttributes="Bold" TextColor="#F5F5F5" CharacterSpacing="0.3"/>
                        <Label Text="Explora nuestros platillos" FontSize="12" TextColor="#666666"/>
                    </VerticalStackLayout>
                </HorizontalStackLayout>
                <BoxView HeightRequest="3" Color="#fc4b08" WidthRequest="40" HorizontalOptions="Start" Margin="0,4,0,0">
                    <BoxView.Shadow>
                        <Shadow Brush="#fc4b08" Offset="0,0" Radius="8" Opacity="0.5"/>
                    </BoxView.Shadow>
                </BoxView>
            </VerticalStackLayout>
        </Border>

        <!-- ══ Search Bar ══ -->
        <Border Grid.Row="1" BackgroundColor="#141414" Margin="16,10,16,8" Padding="4,0" 
                StrokeThickness="1" Stroke="#1E1E1E">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="16"/>
            </Border.StrokeShape>
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,2" Radius="8" Opacity="0.2"/>
            </Border.Shadow>
            <SearchBar x:Name="searchBar" Placeholder="Buscar platillo..." TextColor="White" PlaceholderColor="#555555" BackgroundColor="Transparent" CancelButtonColor="#FF6B00" TextChanged="OnSearchTextChanged"/>
        </Border>

        <!-- ══ Filter Chips ══ -->
        <ScrollView Grid.Row="2" Orientation="Horizontal" Margin="16,0,16,10" HorizontalScrollBarVisibility="Never">
            <HorizontalStackLayout Spacing="8">
                <Button Text="Todos" x:Name="btnFiltroTodos" Clicked="OnFiltroClicked" BackgroundColor="#FF6B00" TextColor="White" CornerRadius="20" HeightRequest="38" Padding="18,0" FontAttributes="Bold" FontSize="13">
                    <Button.Shadow>
                        <Shadow Brush="#fc4b08" Offset="0,2" Radius="8" Opacity="0.3"/>
                    </Button.Shadow>
                </Button>
                <Button Text="Comidas" x:Name="btnFiltroComida" Clicked="OnFiltroClicked" BackgroundColor="#141414" TextColor="#888888" CornerRadius="20" HeightRequest="38" Padding="18,0" FontSize="13" BorderWidth="1" BorderColor="#1E1E1E"/>
                <Button Text="Bebidas" x:Name="btnFiltroBebidas" Clicked="OnFiltroClicked" BackgroundColor="#141414" TextColor="#888888" CornerRadius="20" HeightRequest="38" Padding="18,0" FontSize="13" BorderWidth="1" BorderColor="#1E1E1E"/>
                <Button Text="Postres" x:Name="btnFiltroPostres" Clicked="OnFiltroClicked" BackgroundColor="#141414" TextColor="#888888" CornerRadius="20" HeightRequest="38" Padding="18,0" FontSize="13" BorderWidth="1" BorderColor="#1E1E1E"/>
            </HorizontalStackLayout>
        </ScrollView>

        <!-- ══ Dish List ══ -->
        <CollectionView Grid.Row="3" x:Name="listaMenu" Margin="16,0,16,16">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border BackgroundColor="#111111" Margin="0,5" Padding="12" StrokeThickness="1" Stroke="#1A1A1A">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="18"/>
                        </Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="Black" Offset="0,4" Radius="14" Opacity="0.35"/>
                        </Border.Shadow>

                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnPlatilloTapped" CommandParameter="{Binding .}"/>
                        </Border.GestureRecognizers>

                        <Grid ColumnDefinitions="100,*" ColumnSpacing="14">
                            <!-- Image -->
                            <Border StrokeThickness="1" Stroke="#1E1E1E" BackgroundColor="#0D0D0D">
                                <Border.StrokeShape><RoundRectangle CornerRadius="16"/></Border.StrokeShape>
                                <Image Source="{Binding FotografiaUrl}" HeightRequest="90" WidthRequest="90" Aspect="AspectFill">
                                    <Image.Clip>
                                        <RoundRectangleGeometry CornerRadius="16" Rect="0,0,90,90"/>
                                    </Image.Clip>
                                </Image>
                            </Border>

                            <!-- Info -->
                            <VerticalStackLayout Grid.Column="1" Spacing="4">
                                <Label Text="{Binding Nombre}" FontSize="16" FontAttributes="Bold" TextColor="#F0F0F0" CharacterSpacing="0.3"/>
                                <Label Text="{Binding Descripcion}" FontSize="12" TextColor="#777777" MaxLines="2" LineBreakMode="TailTruncation"/>

                                <Grid ColumnDefinitions="*,Auto" Margin="0,8,0,0">
                                    <HorizontalStackLayout Spacing="4" VerticalOptions="Center">
                                        <Border StrokeThickness="0" BackgroundColor="#1C1206" Padding="10,4">
                                            <Border.StrokeShape><RoundRectangle CornerRadius="8"/></Border.StrokeShape>
                                            <Label Text="{Binding Precio, StringFormat='$ {0:F2}'}" FontSize="16" FontAttributes="Bold" TextColor="#fc4b08"/>
                                        </Border>
                                    </HorizontalStackLayout>

                                    <Button Grid.Column="1" Text="+" BackgroundColor="#fc4b08" TextColor="White" WidthRequest="38" HeightRequest="38" CornerRadius="19" Clicked="OnAgregarClicked" CommandParameter="{Binding .}" FontSize="18" FontAttributes="Bold">
                                        <Button.Shadow>
                                            <Shadow Brush="#fc4b08" Offset="0,2" Radius="8" Opacity="0.3"/>
                                        </Button.Shadow>
                                    </Button>
                                </Grid>
                            </VerticalStackLayout>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- ══ FAB ══ -->
        <Grid Grid.RowSpan="4" HorizontalOptions="End" VerticalOptions="End" Margin="20">
            <Button x:Name="fabCarrito" Text="🛒" BackgroundColor="#fc4b08" TextColor="White" FontSize="22" WidthRequest="65" HeightRequest="65" CornerRadius="32" Clicked="OnVerCarritoClicked">
                <Button.Shadow>
                    <Shadow Brush="#fc4b08" Offset="0,4" Radius="16" Opacity="0.5"/>
                </Button.Shadow>
            </Button>

            <Border x:Name="badgeCarritoMenu" BackgroundColor="#FF3B30" WidthRequest="22" HeightRequest="22" HorizontalOptions="End" VerticalOptions="Start" TranslationX="5" TranslationY="-5" StrokeThickness="2" Stroke="#0A0A0A" IsVisible="False">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="11"/>
                </Border.StrokeShape>
                <Label x:Name="lblCantidadCarrito" Text="0" FontSize="11" TextColor="White" FontAttributes="Bold" HorizontalOptions="Center" VerticalOptions="Center"/>
            </Border>
        </Grid>
    </Grid>
</ContentPage>
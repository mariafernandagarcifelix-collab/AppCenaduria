<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AppCenaduria.Views.VerMenuCliente"
             Title="Menú de la Cenaduría"
             BackgroundColor="#0A0A0A">

    <Grid RowDefinitions="Auto, Auto, Auto, *">

        <Label Grid.Row="0" Text="¿Qué se te antoja hoy?" FontSize="22" TextColor="White" Margin="16,16,16,6" FontAttributes="Bold"/>

        <Border Grid.Row="1" StrokeThickness="1" Stroke="#2A2A2A" BackgroundColor="#1A1A1A" Margin="16,0,16,10" Padding="5,0">
            <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
            <SearchBar x:Name="searchBar" Placeholder="Buscar platillo..." TextColor="White" PlaceholderColor="#777777" BackgroundColor="Transparent" CancelButtonColor="#fc4b08" TextChanged="OnSearchTextChanged"/>
        </Border>

        <ScrollView Grid.Row="2" Orientation="Horizontal" Margin="16,0,16,10" HorizontalScrollBarVisibility="Never">
            <HorizontalStackLayout Spacing="10">
                <Button Text="Todos" x:Name="btnFiltroTodos" Clicked="OnFiltroClicked" CornerRadius="16" HeightRequest="36" BackgroundColor="#fc4b08" TextColor="White" FontSize="13" Padding="16,0" FontAttributes="Bold"/>
                <Button Text="Comidas" x:Name="btnFiltroComida" Clicked="OnFiltroClicked" CornerRadius="16" HeightRequest="36" BackgroundColor="#1A1A1A" TextColor="#AAAAAA" FontSize="13" Padding="16,0" FontAttributes="Bold"/>
                <Button Text="Bebidas" x:Name="btnFiltroBebidas" Clicked="OnFiltroClicked" CornerRadius="16" HeightRequest="36" BackgroundColor="#1A1A1A" TextColor="#AAAAAA" FontSize="13" Padding="16,0" FontAttributes="Bold"/>
                <Button Text="Postres" x:Name="btnFiltroPostres" Clicked="OnFiltroClicked" CornerRadius="16" HeightRequest="36" BackgroundColor="#1A1A1A" TextColor="#AAAAAA" FontSize="13" Padding="16,0" FontAttributes="Bold"/>
            </HorizontalStackLayout>
        </ScrollView>

        <CollectionView Grid.Row="3" x:Name="listaMenu" Margin="16,0,16,16">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border BackgroundColor="#1A1A1A" Margin="0,8" Padding="10" StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="18"/>
                        </Border.StrokeShape>

                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnPlatilloTapped" CommandParameter="{Binding .}"/>
                        </Border.GestureRecognizers>

                        <Grid ColumnDefinitions="100,*" ColumnSpacing="12">
                            <Image Source="{Binding FotografiaUrl}" HeightRequest="90" WidthRequest="90" Aspect="AspectFill">
                                <Image.Clip>
                                    <RoundRectangleGeometry CornerRadius="16" Rect="0,0,90,90"/>
                                </Image.Clip>
                            </Image>

                            <VerticalStackLayout Grid.Column="1" Spacing="4">
                                <Label Text="{Binding Nombre}" FontSize="16" FontAttributes="Bold" TextColor="White"/>
                                <Label Text="{Binding Descripcion}" FontSize="12" TextColor="#AAAAAA" MaxLines="2"/>

                                <Grid ColumnDefinitions="*,Auto" Margin="0,6,0,0">
                                    <Label Text="{Binding Precio, StringFormat='$ {0:F2}'}" FontSize="18" FontAttributes="Bold" TextColor="#FF6B00"/>
                                    <Label Text="Ver ➔" TextColor="#FF6B00" FontAttributes="Bold" VerticalOptions="Center"/>
                                </Grid>
                            </VerticalStackLayout>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Button Grid.RowSpan="4" Text="🛒" BackgroundColor="#FF6B00" TextColor="White" FontSize="24" WidthRequest="60" HeightRequest="60" CornerRadius="30" HorizontalOptions="End" VerticalOptions="End" Margin="20" Clicked="OnVerCarritoClicked">
            <Button.Shadow>
                <Shadow Brush="Black" Offset="0,4" Radius="10" Opacity="0.5"/>
            </Button.Shadow>
        </Button>

    </Grid>

</ContentPage>
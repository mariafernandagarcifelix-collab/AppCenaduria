<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AppCenaduria.Views.PersonalizarPlatillo"
             Title="Preparar Platillo"
             BackgroundColor="#0A0A0A">

    <ScrollView>
        <VerticalStackLayout Padding="0" Spacing="0">

            <!-- ══ Hero Image ══ -->
            <Grid HeightRequest="260">
                <Border StrokeThickness="0" BackgroundColor="#111111" Padding="0" HeightRequest="260">
                    <Border.StrokeShape><RoundRectangle CornerRadius="0,0,32,32"/></Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="0,10" Radius="24" Opacity="0.6"/>
                    </Border.Shadow>
                    <Image x:Name="imgPlatillo" HeightRequest="260" Aspect="AspectFill">
                        <Image.Clip>
                            <RoundRectangleGeometry CornerRadius="0,0,32,32" Rect="0,0,500,260"/>
                        </Image.Clip>
                    </Image>
                </Border>
                <!-- Gradient Overlay -->
                <BoxView BackgroundColor="#0A0A0A" Opacity="0.4" HeightRequest="100" 
                         VerticalOptions="End">
                    <BoxView.Shadow>
                        <Shadow Brush="#0A0A0A" Offset="0,-30" Radius="40" Opacity="0.8"/>
                    </BoxView.Shadow>
                </BoxView>
            </Grid>

            <VerticalStackLayout Padding="22,18,22,0" Spacing="16">

                <!-- ══ Dish Info ══ -->
                <VerticalStackLayout Spacing="6" HorizontalOptions="Center" Margin="0,0,0,0">
                    <Label x:Name="lblNombre" FontSize="30" FontAttributes="Bold" TextColor="#F5F5F5" 
                           HorizontalOptions="Center" CharacterSpacing="0.5"/>
                    <Label x:Name="lblDescripcion" TextColor="#666666" FontSize="14" 
                           HorizontalOptions="Center" HorizontalTextAlignment="Center"/>
                    <BoxView HeightRequest="3" Color="#fc4b08" WidthRequest="40" HorizontalOptions="Center" Margin="0,8,0,0">
                        <BoxView.Shadow>
                            <Shadow Brush="#fc4b08" Offset="0,0" Radius="8" Opacity="0.5"/>
                        </BoxView.Shadow>
                    </BoxView>
                    <!-- Price in accent card -->
                    <Border StrokeThickness="1" Stroke="#2A1A0A" BackgroundColor="#1C1206" 
                            Padding="22,8" HorizontalOptions="Center" Margin="0,8,0,0">
                        <Border.StrokeShape><RoundRectangle CornerRadius="14"/></Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="#fc4b08" Offset="0,0" Radius="12" Opacity="0.15"/>
                        </Border.Shadow>
                        <Label x:Name="lblPrecio" FontSize="26" FontAttributes="Bold" TextColor="#fc4b08" 
                               HorizontalOptions="Center"/>
                    </Border>
                </VerticalStackLayout>

                <!-- ══ Quantity Selector ══ -->
                <Border StrokeThickness="1" Stroke="#1E1E1E" BackgroundColor="#111111" Padding="22,20">
                    <Border.StrokeShape><RoundRectangle CornerRadius="22"/></Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="0,4" Radius="14" Opacity="0.3"/>
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="16">
                        <HorizontalStackLayout Spacing="8" HorizontalOptions="Center">
                            <BoxView WidthRequest="4" HeightRequest="14" Color="#fc4b08" VerticalOptions="Center">

                            </BoxView>
                            <Label Text="CANTIDAD" TextColor="#888888" FontSize="11" FontAttributes="Bold" 
                                   CharacterSpacing="1.5" VerticalOptions="Center"/>
                        </HorizontalStackLayout>
                        <HorizontalStackLayout HorizontalOptions="Center" Spacing="24">
                            <!-- Minus -->
                            <Border StrokeThickness="1" Stroke="#252525" BackgroundColor="#0F0F0F" 
                                    WidthRequest="56" HeightRequest="56">
                                <Border.StrokeShape><RoundRectangle CornerRadius="18"/></Border.StrokeShape>
                                <Border.Shadow>
                                    <Shadow Brush="Black" Offset="0,2" Radius="6" Opacity="0.3"/>
                                </Border.Shadow>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnMenosClicked"/>
                                </Border.GestureRecognizers>
                                <Label Text="−" FontSize="28" FontAttributes="Bold" TextColor="#777777" 
                                       HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>

                            <!-- Count -->
                            <Border StrokeThickness="2" Stroke="#fc4b08" BackgroundColor="#1C1206" 
                                    WidthRequest="74" HeightRequest="56">
                                <Border.StrokeShape><RoundRectangle CornerRadius="18"/></Border.StrokeShape>
                                <Border.Shadow>
                                    <Shadow Brush="#fc4b08" Offset="0,0" Radius="14" Opacity="0.25"/>
                                </Border.Shadow>
                                <Label x:Name="lblCantidad" Text="1" FontSize="28" FontAttributes="Bold" 
                                       TextColor="#fc4b08" HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>

                            <!-- Plus -->
                            <Border StrokeThickness="1" Stroke="#252525" BackgroundColor="#0F0F0F" 
                                    WidthRequest="56" HeightRequest="56">
                                <Border.StrokeShape><RoundRectangle CornerRadius="18"/></Border.StrokeShape>
                                <Border.Shadow>
                                    <Shadow Brush="Black" Offset="0,2" Radius="6" Opacity="0.3"/>
                                </Border.Shadow>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnMasClicked"/>
                                </Border.GestureRecognizers>
                                <Label Text="＋" FontSize="28" FontAttributes="Bold" TextColor="#777777" 
                                       HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                        </HorizontalStackLayout>
                    </VerticalStackLayout>
                </Border>

                <!-- ══ Special Notes ══ -->
                <Border StrokeThickness="1" Stroke="#1E1E1E" BackgroundColor="#111111" Padding="22,20">
                    <Border.StrokeShape><RoundRectangle CornerRadius="22"/></Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="0,4" Radius="14" Opacity="0.3"/>
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="14">
                        <HorizontalStackLayout Spacing="8">
                            <BoxView WidthRequest="4" HeightRequest="14" Color="#fc4b08" VerticalOptions="Center">

                            </BoxView>
                            <Label Text="NOTAS ESPECIALES" TextColor="#888888" FontSize="11" 
                                   FontAttributes="Bold" CharacterSpacing="1" VerticalOptions="Center"/>
                        </HorizontalStackLayout>
                        <Border StrokeThickness="1" Stroke="#252525" BackgroundColor="#0D0D0D" Padding="16,12">
                            <Border.StrokeShape><RoundRectangle CornerRadius="16"/></Border.StrokeShape>
                            <Editor x:Name="txtComentarios" 
                                    Placeholder="Ej. Sin cebolla, con extra de salsa roja..." 
                                    PlaceholderColor="#333333" TextColor="White" 
                                    BackgroundColor="Transparent" HeightRequest="85" FontSize="14"/>
                        </Border>

                        <HorizontalStackLayout Spacing="6" Margin="0,2,0,0">
                            <Label Text="💡" FontSize="11"/>
                            <Label Text="Si deseas platillos con especificaciones diferentes, agrégalos de uno en uno." 
                                   TextColor="#444444" FontSize="11" FontAttributes="Italic"/>
                        </HorizontalStackLayout>
                    </VerticalStackLayout>
                </Border>

                <!-- ══ CTA Button ══ -->
                <Button Text="Añadir al Carrito" 
                        Clicked="OnAñadirCarritoClicked"
                        BackgroundColor="#fc4b08" 
                        TextColor="White" 
                        FontAttributes="Bold" 
                        FontSize="17"
                        CornerRadius="18" 
                        HeightRequest="58" 
                        Margin="0,8,0,34"
                        CharacterSpacing="0.5">
                    <Button.Shadow>
                        <Shadow Brush="#fc4b08" Offset="0,6" Radius="24" Opacity="0.45"/>
                    </Button.Shadow>
                </Button>

            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>